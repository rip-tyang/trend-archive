": "", "short_content": "", "type": 0, "state": 0, "ctime": 1494680531, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1296": {"data": {"tag_id": 1296, "tag_name": "经典", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "58283": {"data": {"tag_id": 58283, "tag_name": "古装", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "9013": {"data": {"tag_id": 9013, "tag_name": "神话", "cover": "http://i0.hdslb.com/bfs/tag/9c0601ec0e4cac193b0ce58f8e986fe6f0bde42e.jpg", "head_cover": "", "content": "2010年，时尚青年易小川（胡歌饰演）来到父亲易教授的考古发掘现场，却意外卷入一起抢夺文物的事件。机缘巧合之下，他误打开了一个神秘的古代宝盒，与考古队的厨师高要一起穿越时空，回到了2200多年前的秦朝。在一次次的奇遇和历险之中，易小川经历了刻骨铭心的爱情，结交了忠肝义胆的朋友，蜕变成了仁心济世的蒙毅；而原本胆小怕事的高要，在经受了一连串致命打击后心性逆转，充满仇恨的心灵在权利的诱惑下变得贪婪冷酷，不择手段。2010年，哥哥易大川（任泉饰演）与父母一直没有放弃找到弟弟易小川的希望，他们一边对抗神秘势力的阻扰破坏，一边破解着一个个与易小川失踪有关的谜团。历险途中，易小川的父母解开了困扰他们多年的心结，易大川战胜了内心的胆怯，找到了自己的真爱。最后，他们打开了传说中的宝藏，找到了易小川的下落，全家人终得团聚，创下了令人感动的神话。可是小川心爱的玉漱公主却因长生药失效离他而去，小川对着电影版神话海报上的玉漱公主（金喜善饰）说：“你没有她漂亮！”对于易小川来说，这不仅仅是一个神话，还是一段真实。最后，小川孤独地走在街上，倾诉着对玉漱深沉的思念。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "8227": {"data": {"tag_id": 8227, "tag_name": "古风", "cover": "http://i0.hdslb.com/bfs/tag/535d44fb751b0613858303027d43ac2a63ba7d24.jpg", "head_cover": "", "content": "“古风”是一类新型的文化。“古风”以中国的传统文化为基调，结合中国传统的文学、琴棋书画、诗词歌赋等，经过不断的发展磨合，形成了比较完备的音乐、文学、绘画等艺术形式。古风文化正逐渐流行，受到越来越多的人喜爱。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "397007": {"data": {"tag_id": 397007, "tag_name": "八仙过海", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "921129": {"data": {"tag_id": 921129, "tag_name": "吕洞宾", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "106885": {"data": {"tag_id": 106885, "tag_name": "八仙", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1153887": {"data": {"tag_id": 1153887, "tag_name": "八仙的传说", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "45711263": {"data": {"tag_id": 45711263, "tag_name": "影视神仙剪刀手", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1695830708, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "50726457": {"data": {"tag_id": 50726457, "tag_name": "B站好片有奖种草", "cover": "", "head_cover": "", "content": "", "short_co
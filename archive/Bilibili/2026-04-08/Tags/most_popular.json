, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "518001": {"data": {"tag_id": 518001, "tag_name": "妆容", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1801609": {"data": {"tag_id": 1801609, "tag_name": "暑假工", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1469071531, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "81783202": {"data": {"tag_id": 81783202, "tag_name": "我的仿妆灵感簿", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1757415470, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "2544": {"data": {"tag_id": 2544, "tag_name": "美剧", "cover": "http://i0.hdslb.com/bfs/tag/d0b0472a4b988b0fb4bed1ed83b168bc375088d5.jpg", "head_cover": "", "content": "“美剧”是中国人对美国电视剧集的简称。上世纪80年代，一部拍摄于1970年的《大西洋底来的人》成为敞开国门之后中国人窥视美国的窗口，麦克·哈里斯 脸上的蛤蟆镜一度成为时尚青年的标志。《加里森敢死队》的热播、停播与复播更是中国人观念变化的晴雨表。《成长的烦恼》让我们走进美国家庭 ，体验了代际沟通的可能及其背后的美国式幽默。凡此种种，都已成为那个年代的文化切片。在长期的发展历程中，美剧的许多传统得以逐步确立，其中“季”的运营模式最为现代中国观众所了解。“季”是各大电视网播出新作品的季节，一般美国商业电视以每年从9月中旬开始到次年4月下旬，时长约30周。每年秋季，美国电视网纷纷推出自己的新剧，或者延续之前已经获得成功的经典剧集。新季以美国电视艺术与科学协会主办的“艾美奖”颁奖典礼为序幕。这段时间天气较冷，人们一般较少外出，电视的开机率和收视率自大幅提升。通过这种每年固定的播出时段，我们可以在许多长寿的美剧中找寻美国社会变迁的轨迹。由于2011年几大视频网站陆续在海外上市，许多优秀的美剧将出现在中国内地的电视屏幕上。一部美国电视剧一般25集左右，这是由美国特有的播映方式决定的。美国电视剧一般一个星期只播一集，因此25集正好够播一季。美国的电视剧是边拍边播的，他们很注重收视率，一部收视率低下的电视剧是无法生存的，只要吸引不了观众的注意力，那么不管该剧的情节进行到何处，电视台都毫不留情地腰斩。电视网是美国电视体系的主体，本质上是一家经营电视节目的大公司。通常，各大电视网在全国各地拥有许多电视台，他们向这些电视台提供节目内容。美国主要的电视网有以下几个：哥伦比亚广播公司（CBS）、全国广播公司（NBC）、美国广播公司（ABC）、福克斯广播公司（FOX）、哥伦比亚及华纳兄弟联合电视网（CW）、家庭电视广播网（HBO=Home Box Office）。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "11310162": {"data": {"tag_id": 11310162, "tag_name": "祖国人", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1564536563, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "27111847": {"data": {"tag_id": 27111847, "tag_name": "黑袍纠察队解析", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1654939685, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "59263664": {"data": {"tag_id": 59263664, "tag_name": "黑袍解析", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1721304483, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "92520834": {"data": {"tag_id": 92520834, "tag_name": "黑牌纠察队最终季", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1775664561, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "92520890": {"data": {"tag_id": 92520890, "tag_name": "黑袍纠察队最终季解析", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1775664684, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0
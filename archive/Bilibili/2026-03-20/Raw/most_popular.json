null, "rcmd_reason": {"content": "百万播放", "corner_mark": 1}}, {"aid": 116260654358399, "videos": 1, "tid": 172, "tname": "手机游戏", "copyright": 1, "pic": "http://i1.hdslb.com/bfs/archive/70a1d78336ff6d7a4dbd8307c8f9ac34bedc04b9.jpg", "title": "桑多涅，饿饿，饭饭~", "pubdate": 1774003200, "ctime": 1773997189, "desc": "这个月事情比较多，所以鸽了亿点时间QAQ\n\n哥伦比娅满脸忧愁的来到桑多涅床前，想把桑多涅叫醒。桑多涅不情愿地睁开一只眼，哥伦比娅见桑多涅醒了立马开心地笑起来。“桑多涅，饿饿，饭饭~”， 哥伦比娅指着自己的嘴巴说到，想让桑多涅给自己做早餐。桑多涅还以为是什么事情，于是睡意朦胧地说：“大早上的，先让我再睡一会”，然后翻个身打算继续睡，但身后的发条让她难以翻身。此时哥伦比娅使出必杀技，在桑多涅耳边唱歌。在多重干扰下，桑多涅不情不愿起床去做早餐。哥伦比娅躺到桑多涅睡觉的位置，也学桑多涅睡觉不肯起床，想以此逗逗桑多", "state": 0, "duration": 156, "mission_id": 4061655, "rights": {"bp": 0, "elec": 0, "download": 0, "movie": 0, "pay": 0, "hd5": 1, "no_reprint": 1, "autoplay": 1, "ugc_pay": 0, "is_cooperation": 0, "ugc_pay_preview": 0, "no_background": 0, "arc_pay": 0, "pay_free_watch": 0}, "owner": {"mid": 396657882, "name": "叶玲秋雨", "face": "https://i0.hdslb.com/bfs/face/39418591fe2c7d1ce4152f74eab5c830b8a93977.jpg"}, "stat": {"aid": 116260654358399, "view": 476926, "danmaku": 677, "reply": 1850, "favorite": 26680, "coin": 23040, "share": 5309, "now_rank": 0, "his_rank": 56, "like": 73749, "dislike": 0, "vt": 0, "vv": 476926, "fav_g": 0, "like_g": 0}, "dynamic": "桑多涅：哥伦比亚！下次吃饭别叫上我！（久等啦）", "cid": 36836084400, "dimension": {"width": 3840, "height": 2160, "rotate": 0}, "season_id": 2016314, "short_link_v2": "https://b23.tv/BV1z9AnzmETK", "first_frame": "http://i2.hdslb.com/bfs/storyff/_00002jpb93bsqq1zk2tgfgcshkitrqb_firsti.jpg", "pub_location": "加拿大", "cover43": "http://i0.hdslb.com/bfs/archive/c78365d8c9efca815b6087b9ccb7fabe6c534298.jpg", "tidv2": 2037, "tnamev2": "同人动画", "pid_v2": 1005, "pid_name_v2": "二次元", "bvid": "BV1z9AnzmETK", "season_type": 0, "is_ogv": false, "ogv_info": null, "enable_vt": 0, "ai_rcmd": null, "rcmd_reason": {"content": "7万点赞", "corner_mark": 1}}, {"aid": 116255352688226, "videos": 4, "tid": 172, "tname": "手机游戏", "copyright": 1, "pic": "http://i0.hdslb.com/bfs/archive/15669ce8e001458059610ef1a4fbb95ccd
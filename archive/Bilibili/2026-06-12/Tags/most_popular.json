over": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "7867205": {"data": {"tag_id": 7867205, "tag_name": "家主", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1532941917, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "92792867": {"data": {"tag_id": 92792867, "tag_name": "二次元游戏AI创想大赛", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1776051471, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "156182": {"data": {"tag_id": 156182, "tag_name": "万万没想到", "cover": "http://i0.hdslb.com/bfs/tag/b6ad614adfc505f2f53007c367c1e3be63e73dda.jpg", "head_cover": "", "content": "《万万没想到》以夸张而幽默的方式描绘了屌丝代表王大锤意想不到的传奇故事。剧情内容包罗万象，从当下热门话题到经典历史故事，调侃的视角幽默的语言独树一帜。作为职场界，名医届，相亲届的著名屌丝，王大锤每天的生活都多姿多彩而又变幻莫测。本来只是一场很简单的面试，但在王大锤看来却变成了一个探案现场，最后的面试结果更是让人意想不到；本来很经典的刘备大义摔儿的故事，在王大锤眼里却变成了一场啼笑皆非的闹剧，从而深刻揭露了刘备的另外一面…\r\n　　王大锤代表着在大社会和各种压力下生活的普通群众，他面对的是每一个人都会经历的，而我们每一个人也确实都承受着世间的千奇百怪和万万想不到的意外。影片从王大锤开始，幻化出你我他的普通生活，教会我们对挫折一笑而过决不妥协。\r\n　　本作由叫兽易小星导演，优酷出品，剧组成员为《搞笑漫画日和》中文配音原班人马。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "116764": {"data": {"tag_id": 116764, "tag_name": "童话镇", "cover": "http://i0.hdslb.com/bfs/tag/a07b927f0556bd02b612876a08999df0cc78f3a6.jpg", "head_cover": "", "content": "ABC电视台的新剧《童话镇》(Once Upon a Time)，本剧由Edward Kitsis和Adam Horowitz开发，于2011年10月23日播出。\r\n故事聚焦在一位有着困扰过去的女性Emma来到缅因州的一个小镇上。她逐渐发现在这里，一切并非看起来那样普通，因为这里是一片拥有魔法和神秘力量的土地，那些童话故事在这里都是真实的。魔法或许已被遗忘，但它就在人们的身旁；童话角色或许已不记得自己曾经是谁，但他们还活着。决定世界命运的战争已经开始，但要赢得胜利，Emma必须坦然接受自己的身世，并且像个真正的斗士那样去战斗。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "240305": {"data": {"tag_id": 240305, "tag_name": "歌词改编", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "53473": {"data": {"tag_id": 53473, "tag_name": "搞笑配音", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "3278269": {"data": {"tag_id": 3278269, "tag_name": "配音小剧场", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1488864799, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "272810": {"data": {"tag_id": 272810, "tag_name": "脑洞", "cover": "", "head_cover": "", "content": "1", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "4287": {"data": {"tag_id": 4287, "tag_name": "星际", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "12623367": {"data": {
为“So Band”乐团，在1997年3月29日改名为“五月天”。乐团的名称是来自贝斯手玛莎在网络论坛上的代号。截至2009年6月，夺下三座金曲“最佳乐团奖”，代表作《志明与春娇》、《疯狂世界》、《终结孤单》、《心中无别人》等。另外，S.H.E在第10张专辑Play中有一首歌名为“五月天”，在该歌曲的MV中，五月天成员阿信和Selina为主角。第八个新专辑《第二人生》。\r\n", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "103326": {"data": {"tag_id": 103326, "tag_name": "官方MV", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "249296": {"data": {"tag_id": 249296, "tag_name": "回到那一天", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "60269": {"data": {"tag_id": 60269, "tag_name": "如烟", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "2214961": {"data": {"tag_id": 2214961, "tag_name": "华语现场", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1470060823, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}}
643aac5.jpg", "head_cover": "", "content": "三国电视剧和电视剧衍生视频\r\n根据中国古典文学四大名著之一的《三国演义》改编电视剧和电视剧衍生，剧演述的是三国时代的故事，是魏、蜀、吴的兴亡史，起于桃园结义，终于三国归晋。着重表现的是从东汉末年到西晋初年将近一个世纪中多个政治集团间错综复杂、紧张尖锐的斗争，这种斗争发展成为连接不断的对政治权力的争夺和军事冲突，给人们描绘出三国时代政治风云的彩色画卷，展示出一幅幅波澜壮阔、惊心动魄的战斗风云图。\r\n", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "27930": {"data": {"tag_id": 27930, "tag_name": "翻拍", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "5696272": {"data": {"tag_id": 5696272, "tag_name": "仿妆不仿人", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1514373875, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "3158": {"data": {"tag_id": 3158, "tag_name": "战争", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "4294870": {"data": {"tag_id": 4294870, "tag_name": "懂王", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1502539308, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "161681": {"data": {"tag_id": 161681, "tag_name": "黎巴嫩", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0
在逼基层干部“纸上种田”？丨中听】\n据央视报道，湖南江华，实际种水稻约23.8万亩，上报近39万亩——差了约15万亩，全靠纸面补齐。好家伙，原来种粮任务不是在地里完成的，是在办公室里完成的。\n但我想问一个更根本的问题：那些没种水稻的田，荒了吗？\n没有。农民种了南瓜、苦瓜、芋头、罗汉果。田地没有荒废，庄稼长势喜人。关键在于，农民也没有因此冒领一分钱的种粮补贴。\n那问题来了：农民在自己的地上，种了合法作物，没荒地，没骗补，怎么就成了需要“整改”的问题？\n《土地管理法实施条例》第", "state": 0, "duration": 94, "mission_id": 4066767, "rights": {"bp": 0, "elec": 0, "download": 0, "movie": 0, "pay": 0, "hd5": 0, "no_reprint": 1, "autoplay": 1, "ugc_pay": 0, "is_cooperation": 0, "ugc_pay_preview": 0, "no_background": 0, "arc_pay": 0, "pay_free_watch": 0}, "owner": {"mid": 522653994, "name": "大象新闻", "face": "https://i0.hdslb.com/bfs/face/004082fc2ecfba940f63416685741aad721a37be.jpg"}, "stat": {"aid": 116929041798381, "view": 378284, "danmaku": 126, "reply": 893, "favorite": 1285, "coin": 1229, "share": 1311, "now_rank": 0, "his_rank": 0, "like": 27424, "dislike": 0, "vt": 0, "vv": 378284, "fav_g": 0, "like_g": 0}, "dynamic": "", "cid": 40007369313, "dimension": {"width": 1080, "height": 1920, "rotate": 0}, "short_link_v2": "https://b23.tv/BV1hsKG6KEVb", "first_frame": "http://i1.hdslb.com/bfs/storyff/_000039kr3setui7172uts25v89xo7bb_firsti.jpg", "pub_location": "河南", "cover43": "http://i2.hdslb.com/bfs/archive/6705a8b65f4628b12e2e96be86b75fce10cfc469.jpg", "tidv2": 2082, "tnamev2": "社会资讯", "pid_v2": 1009, "pid_name_v2": "资讯", "bvid": "BV1hsKG6KEVb", "season_type": 0, "is_ogv": false, "ogv_info": null, "enable_vt": 0, "ai_rcmd": null, "rcmd_reason": {"content": "", "corner_mark": 0}}, {"aid": 116916760877064, "videos": 1, "tid": 238, "tname": "运动综合", "copyright": 1, "pic": "http://i1.hdslb.com/bfs/archive/f4677d90dcea3fc82f17e0603805679df4f126a8.jpg", "title": "路边摊吃盒饭 吃成摊主", "pubdate": 1784086200, "ctime": 1784008757, "desc": "", "state": 0, "duration": 443, "rights": {"bp": 0, "elec": 0, "download": 0, "movie": 0, "pay": 0, "hd5": 0, "no_reprint": 1, "autoplay": 1, "ugc_pay": 0, "is_cooperation": 0, "ugc_pay_preview": 0, "no_background": 0, "arc_pay": 0, "pay_free_watch": 0}, "owner": {"mid": 691099655, "na
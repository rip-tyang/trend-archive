count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "3015032": {"data": {"tag_id": 3015032, "tag_name": "枪支弹药", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1483272006, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "27544978": {"data": {"tag_id": 27544978, "tag_name": "热点观察局", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1656563574, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "2947": {"data": {"tag_id": 2947, "tag_name": "特摄", "cover": "http://i0.hdslb.com/bfs/archive/11d6f73281947ac0d0371897241ad9ef5530b6b6.jpg", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "963": {"data": {"tag_id": 963, "tag_name": "奥特曼", "cover": "http://i0.hdslb.com/bfs/tag/0f84368a89745bdbe5dd75bf1e7a5a17cc4ac8e2.jpg", "head_cover": "", "content": "奥特曼（Ultraman 日：ウルトラマン）是日本圆谷株式会社拍摄的科学空想特摄电视连续剧，由杂志连载、电影、电视剧变成节目演变出现。奥特曼在普通人眼中是高大的巨人，就如同神一般的存在，可是他们对于自己的种族，自己的星球来说也只不过是一个普通人。超进化给他们带来了完善的生命形态，同时也使他们背负起了沉重的历史责任，在这种历史责任感驱使下，光之巨人的足迹遍步宇宙，而其中有这么几位巨人，他们来到了我们所在的地球，邂逅了宇宙中最奇妙也是最难以捉摸的生命体—人类。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "281": {"data": {"tag_id": 281, "tag_name": "MAD", "cover": "http://i0.hdslb.com/bfs/tag/88aae270ab94246268a6402c6af98e51308e87a4.jpg", "head_cover": "", "content": "MAD = M@D = MAD MOVIE\r\n它是电玩文化、动漫文化、同人文化界別中的多媒体作品。一般作品為一段有关的影片剪辑，配以作者喜欢的音樂，近似同人MV 形式的存在。不同的地方是MAD片的重点在于影片，对有关动画或电玩致敬，而相对同人MV的重点則放在音乐之上。当然亦有一些是只作声音的剪辑或只有画面的剪辑严格而言亦可算作MAD的。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "68": {"data": {"tag_id": 68, "tag_name": "鬼畜", "cover": "http://i0.hdslb.com/bfs/archive/5f42290e9299eceb7dfce4b932b497d1255ea847.jpg", "head_cover": "http://i0.hdslb.com/bfs/archive/af941ccd50c12c1ccd91869bfcc6fb22d71b458f.png", "content": "起源于NICONICO动画，由最早出现的音MAD《最终鬼畜妹フランドール・S》中的“鬼畜”略称而得名。", "short_content": "以音频调教创作为主体的二次创作", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "12955508": {"data": {"tag_id": 12955508, "tag_name": "泽塔奥特曼", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1579340416, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "113843": {"data": {"tag_id": 113843, "tag_name": "抽象", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}}
危难正渐渐临到自己身上……\r\n\r\nSteins;Gate（命运石之门，日语：シュタインズ・ゲート）是2009年10月15日发售的一款Xbox 360游戏，Windows版本于2010年8月26日发售。继《CHAOS;HEAD》之后，5pb.与Nitro+合作企划的“科学系列”冒险游戏（ADV）的第二作，假想科学ADV。Fami通赏2009优秀赏受奖作品。已于2011年4月TV动画化。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "24874067": {"data": {"tag_id": 24874067, "tag_name": "终末地", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1646897826, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "24874086": {"data": {"tag_id": 24874086, "tag_name": "明日方舟终末地", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1646897917, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "26474923": {"data": {"tag_id": 26474923, "tag_name": "Mygo", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1652699902, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "64147375": {"data": {"tag_id": 64147375, "tag_name": "三角洲欢乐剧场", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1730885176, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "73703036": {"data": {"tag_id": 73703036, "tag_name": "凑企鹅", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1742114051, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hate
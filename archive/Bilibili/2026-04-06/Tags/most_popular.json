tra_attr": 0}, "day_count": 1}, "91434270": {"data": {"tag_id": 91434270, "tag_name": "周杰伦新专辑二创大赛", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1773763216, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "91680091": {"data": {"tag_id": 91680091, "tag_name": "ChildrenOfTheSun", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1774229027, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "3390": {"data": {"tag_id": 3390, "tag_name": "校园", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 2}, "141960": {"data": {"tag_id": 141960, "tag_name": "谎言", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "14268": {"data": {"tag_id": 14268, "tag_name": "绫波丽", "cover": "http://i0.hdslb.com/bfs/tag/9dcd2fddca67e3cec17d24d752a26b1583f9a63b.jpg", "head_cover": "", "content": "绫波丽是日本经典动漫作品《新世纪福音战士》中的第一女主角，同时在EVA系列的漫画、剧场版、游戏与新剧场版中均有出场。14岁，灵魂来自莉莉斯，肉体是碇真嗣的母亲碇唯的克隆人，同时也是EVA第一适格者，零号机的专属驾驶员。只爱食素，就读于第三新东京市市立第一中学2年A班。是EVA里含有谜团最多的角色。她作为“三无少女”的始祖，并非没有感情。监督庵野秀明曾经对绫波的声优林原说：“绫波并非没有感情，只是不懂得。”她拥有淡蓝色的短发和红色的眼眸，是一个外表冰冷但又拥有女神象征的角色。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "213413": {"data": {"tag_id": 213413, "tag_name": "解析", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "12691": {"data": {"tag_id": 12691, "tag_name": "碇真嗣", "cover": "http://i0.hdslb.com/bfs/tag/25c5522d5d056545b5f58be2f512fec082e5ff0c.jpg", "head_cover": "", "content": "碇真嗣是日本动画《新世纪福音战士》的主角。他是第三位适格者，也是初号机的驾驶员，是NERV司令官碇源堂与碇唯的独生子。碇源堂在失去碇唯之后，将碇真嗣寄养在亲戚家中；于是碇真嗣十多年来与父亲极少来往，这使他在年幼时就已非常独立，但这同时也是造成他心灵创伤的原因之一。因为被父亲忽视，真嗣有些缺乏自尊，而且变的非常孤僻，在遇到困境或痛苦的时候，经常会选择逃避现实。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "41917": {"data": {"tag_id": 41917, "tag_name": "心理学", "cover": "http://i0.hdslb.com/bfs/tag/1d1f37cce1383027e2d7619b72fd107c170756e7.jpg", "head_cover": "", "content": "心理学（英文名称Psychology）是研究人和动物心理现象发生、发展和活动规律的一门科学。心理学既研究动物的心理（研究动物心理主要是为了深层次地了解、预测人的心理的发生、发展的规律）也研究人的心理，而以人的心理现象为主要研究对象。因此总而言之，言而总之，心理学是研究心理现象和心理规律的一门科学。\n", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "994": {"data": {"tag_id": 994, "tag_name": "新世纪福音战士", "cover": "http://i0.hdslb.com/bfs/tag/64834504aeddc9f968a60bddc8b6a45731230f2f.jpg", "head_cover": "", "content": "2000年，一个科学探险队在南极洲针对被称作“第一使徒”亚当的“光之巨人”进行探险。在对其进行接触实验时，“光之巨人”自毁，从而发生了“第二次冲击”，进而导致世界大战。最后，人类人口减半，地轴偏转、气候改变。根据对“第二次冲击”的调查，联合国在日本箱根成立人工进化研究所（即 GEHIRN）从事EVA（指机器人）的发展研究，后GEHIRN利用在人工进化研究所下方发现的巨大空洞建造了总部。\n 　　另一方面，联合国下属秘密组织SEELE为了使人类进化，开始实行人类补完计划，通过中和每个人的AT力场，使每个人回归LCL之海。\n 　　2004年，EVA初号机进行启动试验时发生事故，碇真嗣的母亲碇唯消失，碇源渡开始执行“碇源渡版本的人类补完计划”。2010年，GEHIRN被改建成NERV。\n 　　2015年开始，根据SEELE人类补完计划剧本的安排，“使徒”开始在日本登陆，并向NERV总部进攻，NERV组织EVA消灭使徒。在NERV与使徒作战的同时，碇源渡秘密地执行它自己的计划。随着时间推移，碇源渡的计划逐渐被SEELE发现，NERV与SEELE产生了矛盾并不断恶化…", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "375": {"data": {"tag_id": 375, "tag_name": "EVA", "cover": "", "head_cover": "", "content": "eva泛指\"TV版\"、\"剧场版\"、\"新剧场版\"与\"漫画版\"等上述ACGN作品，在剧中指代由驾驶员驾驶的机体。 eva TV版全26话，由GAINAX制作，东京电视系自1995年10月4日开始播放。1997年推出两部剧场版「死与新生」与「THE END OF EVANGELION」。1998年3月剧场版 Revival Of EVANGELION 上映。 eva漫画版是贞本义行于1995年为了配合TV版动画上映的而绘制的，虽然是根据原作而画，却因为时间比较早而被误认为原作。 漫画版的连载时间是早于动画上映的，但是构想与企划则是动画在前。漫画的创作也是基于动画的企划而作，并非单纯把动画漫画化，而是贞本义行根据自己理解所作的改编作品。 可以这样理解，漫画版本是贞本义行所理解的eva，而动画版本则是带有庵野秀明理念的eva。 2007年推出制作福音战士新剧场版计划 ，主制作方变更为Khara，第一集简称序，第二集简称破，第三集简称Q，第四集名为《シン・エヴァンゲリオン剧场版:│▌ 》。\":||\"为音乐反复记号;\"||\"则是终止线。另外标题的\"シン\"可以标记为汉字的\"真\"或者是\"新\"。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "84455684": {"data": {"tag_id": 84455684, "tag_name": "橙海飞鸟", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1761727131, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "3137": {"data": {"tag_id": 3137, "tag_name": "明日香", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "44219": {"data": {"tag_id": 44219, "tag_name": "飞鸟", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "us
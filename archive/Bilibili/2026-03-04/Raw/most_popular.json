[{"aid": 116162725675408, "videos": 1, "tid": 200, "tname": "国风舞蹈", "copyright": 1, "pic": "http://i1.hdslb.com/bfs/archive/71400c27f49e5acc1d9b42e98c153f80787a1675.jpg", "title": "纳纯湖：远古的红", "pubdate": 1772502715, "ctime": 1772502715, "desc": "2025年12月，我又回到熟悉的纳纯湖，却闯入了一片无边无际的红。\n\n这是我见过的最古老的红。\n\n我们的星球有四十五亿年的演化史，在这漫长的岁月中，最激动人心的时刻，是生命诞生的那一刻。这一刻，让它成为了浩瀚宇宙中的唯一。\n\n中华文明是地球上最古老的文明之一，在我们的文明里，红，象征喜庆、吉祥，和希望。\n\n从2010年开始，我每年都要来到纳纯湖守候它的奇迹，这一次，它给了我无与伦比的体验，让我更加坚信：永远怀抱希望，永远相信美好！\n\n我的名字，也是红。", "state": 0, "duration": 138, "mission_id": 4059320, "rights": {"bp": 0, "elec": 0, "download": 0, "movie": 0, "pay": 0, "hd5": 1, "no_reprint": 1, "autoplay": 1, "ugc_pay": 0, "is_cooperation": 0, "ugc_pay_preview": 0, "no_background": 0, "arc_pay": 0, "pay_free_watch": 0}, "owner": {"mid": 696490107, "name": "摄影家罗红", "face": "https://i0.hdslb.com/bfs/face/da73a7a9fa072c722254ae816d8205a2b5f3b036.jpg"}, "stat": {"aid": 116162725675408, "view": 1529573, "danmaku": 300, "reply": 492, "favorite": 4565, "coin": 1771, "share": 752, "now_rank": 0, "his_rank": 0, "like": 15808, "dislike": 0, "vt": 0, "vv": 1529573, "fav_g": 0, "like_g": 839}, "dynamic": "", "cid": 36411212739, "dimension": {"width": 3840, "height": 2160, "rotate": 0}, "short_link_v2": "https://b23.tv/BV1NEA9zDEbo", "first_frame": "http://i1.hdslb.com/bfs/storyff/_000006jblazfj8i802v02o9fxov85ub_firsti.jpg", "pub_location": "北京", "cover43": "http://i1.hdslb.com/bfs/archive/a3de6de5616b1efb5c40654506001043131dd52c.jpg", "tidv2": 2158, "tnamev2": "旅游记录", "pid_v2": 1022, "pid_name_v2": "旅游出行", "bvid": "BV1NEA9zDEbo", "season_type": 0, "is_ogv": false, "ogv_info": null, "enable_vt": 0, "ai_rcmd": null, "rcmd_reason": {"content": "", "corner_mark": 0}}, {"aid": 116170543863736, "videos": 1, "tid": 21, "tname": "日常", "copyright": 1, "pic": "http://i2.hdslb.com/bfs/archive/91160e6db97fc86f612f05cfd57245169df6668f.jpg", "title": "非得今儿个走啊", "pubdate": 1772622074, "ctime": 1772622074, "desc": "-", "state": 0, "duration": 239, "rights": {"bp
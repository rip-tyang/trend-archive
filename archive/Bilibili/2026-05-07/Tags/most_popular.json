0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "9500": {"data": {"tag_id": 9500, "tag_name": "宅舞", "cover": "http://i0.hdslb.com/bfs/archive/3d668a697f171fc0ef6468c41dbca6887139ac8b.jpg", "head_cover": "http://i0.hdslb.com/bfs/archive/4125ddf78104150b36462fcb9a56560f795ca0b1.jpg", "content": "宅舞是一个仅在中国大陆地区使用的名词，一般用来指代使用了与ACGN文化有关的音乐作为伴奏所编排的舞蹈作品。", "short_content": "与ACG相关的翻跳、原创舞蹈", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "8259": {"data": {"tag_id": 8259, "tag_name": "光之美少女", "cover": "http://i0.hdslb.com/bfs/tag/ebabb1b4766f82747679e449bf0a5fa366af768e.jpg", "head_cover": "", "content": "  这部动画自2004年开始于日本播放。其不拘泥于传统女童动画公式的故事和设定引起了话题，除了原本订为目标的女童市场，在父母们和一部分的动画迷之间也深受好评，成为了热门作品。\r\n  虽然是以幼稚园到小学中年级的女童为主要客层的作品，但本作在战斗中却不使用魔法般的攻击，反而是像英雄式动画一般以肉搏方式战斗。加上剧中的玩具商品并非直接进行攻击的武器，没有类似“美少女战士”中“礼服蒙面侠”的男性助拳人，将两位女主角的颜色设定为“黑与白”等等，做了许多和从前的类似动画不同的崭新尝试。\r\n  系列导演是执导过“七龙珠”系列等作品，擅长激烈战斗场面的西尾大介。\r\n在“能卖到50亿日圆就等于大成功”的日本女童玩具市场中，以万代公司制造的玩具创下超过100亿日圆收入的佳绩，颠覆了玩具业界的常识。\r\n\r\n", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "2423": {"data": {"tag_id": 2423, "tag_name": "可爱", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "2487164": {"data": {"tag_id": 2487164, "tag_name": "cos", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1470842495, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "a
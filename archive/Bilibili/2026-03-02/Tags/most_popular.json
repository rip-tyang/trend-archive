0136139": {"data": {"tag_id": 30136139, "tag_name": "当代大学生精神状态", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1664616372, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1265": {"data": {"tag_id": 1265, "tag_name": "篮球", "cover": "http://i0.hdslb.com/bfs/tag/3c913f40349db7522bb35965c2d33cf696ce93f2.jpg", "head_cover": "", "content": "篮球是一个由两队参与的球类运动bcw，cc每队出场5名队员目的是将球进入对方球篮框中得分，并阻止对方获得球权和得分。可将球向任何方向传、投、拍、滚或运，但要受规则的限制。篮球比赛的形式多种多样，也有最流行的街头三人篮球赛，是三对三的比赛，更讲究个人技术。当今世界篮球水平最高的联赛是美国的国家篮球协会（NBA）。篮球在1904年列入奥运会的表演项目，到1936年柏林奥运会成为正式项目。女子篮球到1976年蒙特利尔奥运会才成为正式项目。", "short_content": "", "type": 2, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "86338285": {"data": {"tag_id": 86338285, "tag_name": "体育生的搞笑日常", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1764672430, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "8493022": {"data": {"tag_id": 8493022, "tag_name": "内容过于真实", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1538843256, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "82122636": {"data": {"tag_id": 82122636, "tag_name": "中东局势解读", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1757968262, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "23649527": {"data": {"tag_id": 23649527, "tag_name": "搞
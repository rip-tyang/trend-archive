ntent": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "6299": {"data": {"tag_id": 6299, "tag_name": "DECO*27", "cover": "http://i0.hdslb.com/bfs/tag/940cfc030b55d2dd12be9aff650004a06ee72180.jpg", "head_cover": "", "content": "· Vocaloid P 人气Master之一。能够作词、作曲、吉他演奏，也能够演唱。初音未来和GUMI的作曲者。知名曲为:爱言叶、二息歩行、弱虫モンブラン、罪と罚。\r\n· 2011年十月与柴咲コウ、TeddyLoid組成新电音乐团「 galaxias! 」出道。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "290": {"data": {"tag_id": 290, "tag_name": "VOCALOID", "cover": "http://i0.hdslb.com/bfs/archive/20825058199114b09729dc9bd526adcc360ea503.jpg", "head_cover": "http://i0.hdslb.com/bfs/archive/2ff4ea96b2bcd7f28eded29d5a480a54c15473fe.jpg", "content": "VOCALOID是Yamaha所开发的电子音乐制作语音合成软件。输入音调和歌词，便可以合成为人类声音的歌声。", "short_content": "创造专属于你自己的虚拟偶像。", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}}
ag_name": "喜剧", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "589": {"data": {"tag_id": 589, "tag_name": "哲学", "cover": "http://i0.hdslb.com/bfs/tag/fdc6d3c5066ba6bc0f88a411b703d2980cc72b03.jpg", "head_cover": "", "content": "兄贵文化的代表性理念之一.最初来源是因为比利的摔跤视频中常常会有各种不明所里的行为和叫声,总是能引发起观众剧烈的思考: &quot;他们为什么要摔跤!?&quot;&quot;他们为什么要***!?&quot;&quot;为什么要打跟斗!?&quot;&quot;为什么我要看这个视频!?&quot;\r\n随着观众的思考越来越深入,其思考的问题甚至会上升到哲学的地步,所以称为哲♂学.\r\n而兄贵文化发展到现在,哲学这一词汇的含义也在不断发展.在近代日常用语中,哲学可分为名词和形容词.", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "13509": {"data": {"tag_id": 13509, "tag_name": "文学", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "40328": {"data": {"tag_id": 40328, "tag_name": "读书", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "127846": {"data": {"tag_id": 127846, "tag_name": "罗翔", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "775934": {"data": {"tag_id": 775934, "tag_name": "视频播客", "cover": "", "head_cover": "", "content": "", "sho
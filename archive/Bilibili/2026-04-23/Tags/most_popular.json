风云的彩色画卷，展示出一幅幅波澜壮阔、惊心动魄的战斗风云图。\r\n", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "18277": {"data": {"tag_id": 18277, "tag_name": "曹操", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "7781": {"data": {"tag_id": 7781, "tag_name": "新三国", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "51330": {"data": {"tag_id": 51330, "tag_name": "诸葛亮", "cover": "http://i0.hdslb.com/bfs/tag/1065b9c93da3cac5f4f5a0080bdb47176a646719.jpg", "head_cover": "", "content": "诸葛亮，字孔明、号卧龙。三国时期蜀汉丞相、杰出的政治家、军事家、散文家、书法家。著有《出师表》、《诫子书》等。曾发明木牛流马、孔明灯、诸葛连弩。中国古代忠臣的楷模，文学家常写文章以表达对其的赞赏。其鞠躬精粹，死而后已的形象为后世所铭记", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "80600": {"data": {"tag_id": 80600, "tag_name": "刘备", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "64290849": {"data": {"tag_id": 64290849, "tag_name": "新三吐槽", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1731156450, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "at
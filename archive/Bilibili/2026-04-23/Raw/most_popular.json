ort_link_v2": "https://b23.tv/BV1nJohBFEwr", "up_from_v2": 9, "first_frame": "http://i2.hdslb.com/bfs/storyff/_00003pimuvfjozlgk29nlre3997lqob_firsti.jpg", "pub_location": "重庆", "cover43": "http://i1.hdslb.com/bfs/archive/3c4ff49c6d2243f009254d6d2af396f017461ed8.jpg", "tidv2": 2154, "tnamev2": "剧情演绎", "pid_v2": 1021, "pid_name_v2": "小剧场", "bvid": "BV1nJohBFEwr", "season_type": 0, "is_ogv": false, "ogv_info": null, "enable_vt": 0, "ai_rcmd": null, "rcmd_reason": {"content": "5万点赞", "corner_mark": 1}}, {"aid": 116445589543483, "videos": 1, "tid": 124, "tname": "社科·法律·心理", "copyright": 1, "pic": "http://i1.hdslb.com/bfs/archive/904642290ba50b9c0f8e604e17959be55f7a39ec.jpg", "title": "读书究竟让人越读越聪明，还是越读越傲慢？｜罗翔x刘震云x刘旸教主【2026读书日特别策划】", "pubdate": 1776852000, "ctime": 1776819190, "desc": "又是一年一度世界读书日，《一麦三连》邀请到三位重磅嘉宾：百大UP主@罗翔说刑法 、知名作家刘震云、知名喜剧演员@刘旸教主 ，一起来聊聊读书，又不止于读书。我们希望借这样一场对话，由读书切入，聊聊这世间的「道理」——因为书本只是道理的其中一种传播形态。上课、喜剧创作、写小说、和生活里的朋友聊天，都是在「讲道理」。而不管读多少本书，书里的道理，总是要被拿去面对生活的问题。读的书越多，人就一定越能看清楚生活吗？有时候，相比道理，玩笑的力量、幽默的力量反而更能成为我们抵抗荒诞的武器。愿我们都能从书本、从生活里汲取", "state": 0, "duration": 4773, "mission_id": 4064486, "rights": {"bp": 0, "elec": 0, "download": 0, "movie": 0, "pay": 0, "hd5": 1, "no_reprint": 1, "autoplay": 1, "ugc_pay": 0, "is_cooperation": 1, "ugc_pay_preview": 0, "no_background": 0, "arc_pay": 0, "pay_free_watch": 0}, "owner": {"mid": 517327498, "name": "罗翔说刑法", "face": "https://i1.hdslb.com/bfs/face/4e5d0a51273fe3f8fabc700b6a71bb8a38c9e21e.jpg"}, "stat": {"aid": 116445589543483, "view": 1731270, "danmaku": 1162, "reply": 753, "favorite": 48420, "coin": 24345, "share": 9317, "now_rank": 0, "his_rank": 10, "like": 66886, "dislike": 0, "vt": 0, "vv": 1731270, "fav_g": 906, "like_g": 235}, "dynamic": "读的书越多，人就一定越能看清楚生活吗？我们一起聊聊读书、生活和幽默～", "cid": 26001741751, "dimension": {"width": 3840, "height": 2160, "rotate": 0}, "short_link_v2": "https://b23.tv/BV1hkoHBpENz", "first_frame": "http://i1.hdslb.com/bfs/storyff/_00000dxjnk872tju72tqdtchl8wg7zb_firsti.jpg", "pub_location": "北京", "cover4
hdslb.com/bfs/archive/0851d2d08df4a25e5a53fcf2af43aa4097f001c2.jpg", "title": "美国人溜进顺德老人家吃的饭堂：这口感直接把我人整傻了！", "pubdate": 1776931448, "ctime": 1776927498, "desc": "有些地方你只是去耍一哈。\n 有些地方直接把你减肥计划整报废，而且连句不好意思都没得。\n 顺德，就是这种地方。\n顺德就像个孤岛，上头困了一群世界级的大厨……结果这帮人不着急跑，反而开始内卷，看哪个能搞出最离谱、最让人脑壳开花的好吃玩意儿。有些菜咬一口下去，直接灵魂出窍，去找2001年的安吉丽娜·朱莉私会去了，你懂我意思撒。\n我来之前想的是：“行嘛，喝口茶，整点虾饺……估计有点寡淡。”\n结果下一秒，我就遭一群大叔包围了。人家这套早茶加摆龙门阵的流程，比我活的时间都长。千万别把特朗普或者奥巴马带这儿来。这儿的茶", "state": 0, "duration": 1435, "rights": {"bp": 0, "elec": 0, "download": 0, "movie": 0, "pay": 0, "hd5": 0, "no_reprint": 1, "autoplay": 1, "ugc_pay": 0, "is_cooperation": 0, "ugc_pay_preview": 0, "no_background": 0, "arc_pay": 0, "pay_free_watch": 0}, "owner": {"mid": 3546939243104552, "name": "ThatEvanGuy", "face": "https://i2.hdslb.com/bfs/face/62b00721fab4c07f1b2483e60e548766512e44e5.jpg"}, "stat": {"aid": 116452703147830, "view": 433719, "danmaku": 3531, "reply": 1866, "favorite": 2628, "coin": 4841, "share": 736, "now_rank": 0, "his_rank": 0, "like": 15391, "dislike": 0, "vt": 0, "vv": 433719, "fav_g": 4, "like_g": 0}, "dynamic": "", "cid": 37745396768, "dimension": {"width": 1920, "height": 1080, "rotate": 0}, "short_link_v2": "https://b23.tv/BV1GHoeBxEtT", "first_frame": "http://i0.hdslb.com/bfs/storyff/_00002cy2sclfjzo032pzgn862desskb_firsti.jpg", "pub_location": "越南", "cover43": "http://i1.hdslb.com/bfs/archive/8c2cf5a677c0ea4d7d9d7001d6e4f9f201759c96.jpg", "tidv2": 2150, "tnamev2": "美食探店", "pid_v2": 1020, "pid_name_v2": "美食", "bvid": "BV1GHoeBxEtT", "season_type": 0, "is_ogv": false, "ogv_info": null, "enable_vt": 0, "ai_rcmd": null, "rcmd_reason": {"content": "", "corner_mark": 0}}, {"aid": 116453625890512, "videos": 1, "tid": 17, "tname": "单机游戏", "copyright": 3, "pic": "http://i0.hdslb.com/bfs/archive/290e1cdba676510fb6b550944ce61fa5ba6f867f.jpg", "title": "《刺客信条：黑旗 记忆重置》官方10分钟实机演示介绍丨回来了，全都回来了！", "pubdate": 1776961800, "ctime": 1776941746, "desc": "7月9日，我们一起启航！\n感谢爱德华·肯威的配音演员--Matt Ryan为大家带来本次《刺客信条：黑旗 记忆重置》的实机部分介绍，关注阿育，获取本作最新动态！", "stat
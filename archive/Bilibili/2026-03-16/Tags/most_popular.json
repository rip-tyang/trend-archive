1770936": {"data": {"tag_id": 61770936, "tag_name": "阿B车友俱乐部", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1726056094, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "276236": {"data": {"tag_id": 276236, "tag_name": "薛之谦", "cover": "http://i0.hdslb.com/bfs/tag/cda0e5cd0fb5031e00ccfed9fe2be208828f5c92.jpg", "head_cover": "", "content": "薛之谦，中国内地男歌手、词曲创作人、演员，2005年莱卡我型我秀正式以歌手身份出道。目前已有《薛之谦》、《你过得好吗》、《几个你》、《意外》等多张专辑与单曲，2015年6月新歌《演员》位居多家权威音乐榜单榜首。除音乐方面的成绩外，薛之谦还是上上谦串串香火锅店与淘宝UUJULY女装店的老板，以及微博著名段子手。薛之谦微博http://weibo.com/xuezhiqian，百度薛之谦吧http://tieba.baidu.com/xuezhiqian，UUJULY女装店http://uujuly.taobao.com/", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "61519": {"data": {"tag_id": 61519, "tag_name": "快乐大本营", "cover": "http://i0.hdslb.com/bfs/tag/4577016bf124d1df1445ca3b5a5b9770c7d219f6.jpg", "head_cover": "", "content": "《快乐大本营》是湖南电视台于1997年7月11日开办的一档综艺性娱乐节目，是湖南卫视上星以来一直保持的品牌节目之一。节目开始采用全民娱乐的类型，经常邀请一些有特殊才能的人物，一些可爱的孩子来表演，后又转为选秀节目，来选举其主持人；现在多以嘉宾访谈游戏型的综艺节目，经常邀请一些中国大陆、香港、台湾的知名艺人来访谈，游戏等。是湖南卫视的品牌节目之一。观众最喜欢的综艺节目，该节目获得1998年度金鹰奖。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "71602": {"data": {"tag_id": 71602, "tag_name": "张杰", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "42739": {"data": {"tag_id": 42739, "tag_name": "谢娜", "cover": "", "head_cover": "", "c
a_attr": 1}, "day_count": 1}, "431420": {"data": {"tag_id": 431420, "tag_name": "一人分饰多角", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "5951234": {"data": {"tag_id": 5951234, "tag_name": "恶毒女配", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1516472239, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "9525663": {"data": {"tag_id": 9525663, "tag_name": "女主和女配", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1547121581, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "68": {"data": {"tag_id": 68, "tag_name": "鬼畜", "cover": "http://i0.hdslb.com/bfs/archive/5f42290e9299eceb7dfce4b932b497d1255ea847.jpg", "head_cover": "http://i0.hdslb.com/bfs/archive/af941ccd50c12c1ccd91869bfcc6fb22d71b458f.png", "content": "起源于NICONICO动画，由最早出现的音MAD《最终鬼畜妹フランドール・S》中的“鬼畜”略称而得名。", "short_content": "以音频调教创作为主体的二次创作", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 2}, "5485": {"data": {"tag_id": 5485, "tag_name": "死亡笔记", "cover": "http://i0.hdslb.com/bfs/tag/95745dba82c3a7ac36c9b4701c162eb340298469.jpg", "head_cover": "", "content": "“名字被写进这本笔记本的人就会死。”——拿到这本由死神琉克(Ryuuku)所掉落的死亡笔记的人是日本高中生——夜神月（Yagami Light）。月将世界上犯罪者的名字一个个写进笔记本，相信这样的行为是正义，发誓要成为一个没有犯罪的新世界的神。发现有人在制裁犯罪的民众，开始称呼这位制裁者为“基拉”。\r\n另一方面，察觉到基拉出现的ICPO（国际刑事警察组织Interpol）委托一个名为“L”的侦探来调查基拉事件。L是唯一能动员全世界警察的人，世界上很多陷入胶着的案件都是由他查出。他的基本资料没有人知道。认为基拉是“罪恶”的L，用巧妙而大胆的方式证明出“基拉你就在日本关东地区”，在日本设立搜查总部挑战基拉。基拉和L，从此为了揭露彼此的真面目，也为了彼此的正义互相对立...\r\n\r\n\r\n《死亡笔记》，是根据原著漫画改编制作的动画作品。于2006年10月3日至2007年6月26日在日本电视台（NTV）首播，其后亦在Animax及亚洲多间电视台播放。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "18197": {"data": {"tag_id": 18197, "tag_name": "科比", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "14940811": {"data": {"tag_id": 14940811, "tag_name": "雨姐", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1590688410, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "17326659": {"data": {"tag_id": 17326659, "tag_name": "丁真", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1605188225, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "89190": {"data": {"tag_id": 89190, "tag_name": "潜水", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "6280": {"data": {"tag_id": 6280, "tag_name": "事故", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count"
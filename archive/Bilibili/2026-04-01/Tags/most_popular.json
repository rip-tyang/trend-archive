s/archive/8a8a3d683b63fbfbf60f9f82b3a9a8167146471a.png", "head_cover": "http://i0.hdslb.com/bfs/archive/d461e67905be2684c3eadb0ac021ca7ed154cddd.jpg", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "3582": {"data": {"tag_id": 3582, "tag_name": "纯爱", "cover": "http://i0.hdslb.com/bfs/tag/772a885e4f929c188fb3da1bff0ae4359e7e0063.jpg", "head_cover": "", "content": "    纯爱作品表达的是人与人之间单纯而美好的感情，也许在当今这个时代纯爱作品并不能够引起足够多的关注。但我们终归向往生活美好的一面，喜欢美好的事物。因此它所给我们带来的感动与体会都是不会被淡忘的，而这个专题也正是希望能为大家整理出治愈人心的纯爱故事~\r\n    无论是正统的恋爱系 还是纠结的后宫系，无论唯美的百合向还是轻松的BL向，只要作品满怀着爱恋与仰慕的心情，便都可视之为纯爱作品。总之希望大家在欣赏纯爱系作品的同时，能够感受到幸福与治愈~\r\n                                                       ", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "156893": {"data": {"tag_id": 156893, "tag_name": "新人向", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "696": {"data": {"tag_id": 696, "tag_name": "火影", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "43352": {"data": {"tag_id": 43352, "tag_name": "卡点", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, 
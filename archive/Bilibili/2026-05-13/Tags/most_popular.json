content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1265": {"data": {"tag_id": 1265, "tag_name": "篮球", "cover": "http://i0.hdslb.com/bfs/tag/3c913f40349db7522bb35965c2d33cf696ce93f2.jpg", "head_cover": "", "content": "篮球是一个由两队参与的球类运动bcw，cc每队出场5名队员目的是将球进入对方球篮框中得分，并阻止对方获得球权和得分。可将球向任何方向传、投、拍、滚或运，但要受规则的限制。篮球比赛的形式多种多样，也有最流行的街头三人篮球赛，是三对三的比赛，更讲究个人技术。当今世界篮球水平最高的联赛是美国的国家篮球协会（NBA）。篮球在1904年列入奥运会的表演项目，到1936年柏林奥运会成为正式项目。女子篮球到1976年蒙特利尔奥运会才成为正式项目。", "short_content": "", "type": 2, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "32780326": {"data": {"tag_id": 32780326, "tag_name": "牢大", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1671880628, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "2620933": {"data": {"tag_id": 2620933, "tag_name": "ai", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1473727723, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "7375172": {"data": {"tag_id": 7375172, "tag_name": "整活", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1528119428, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "9500": {"data": {"tag_id": 9500, "tag_name": "宅舞", "cover": "http://i0.hdslb.com/bfs/archive/3d668a697f171fc0ef6468c41dbca6887139ac8b.jpg", "head_cover": "http://i0.hdslb.com/bfs/archive/4125ddf78104150b36462fcb9a56560f795ca0b1.jpg", "content": "宅舞是一个仅在中国大陆地区使用的名词，一般用来指代使用了与ACGN文化有关的音乐作为伴奏所编排的舞蹈作品。", "short_content": "与ACG相关的翻跳、原创舞蹈", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "10624": {"data": {"tag_id": 10624, "tag_name": "鹿乃", "cover": "http://i0.hdslb.com/bfs/tag/d49e65ac55f12b56ff78da5a2afa80b06f731bb3.jpg", "head_cover": "", "content": "鹿乃(かの)，Niconico动画上常见萌系唱见，由2010年开始投稿自己的翻唱作品，现有投稿作品60余，个人专辑6张，另外有一首原创vocaloid作品。中文名鹿乃\r\n外文名 かの 国籍 日本 民 族大和 出生地日本广岛 出生日期12月24日\r\n职业歌手 代表作品ハロ/ハワユ\r\n血型A型性别女身 高14*cm\r\n特征：①方言浓郁②NICO培训生中的有残虐倾向③兄控", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "268778": {"data": {"tag_id": 268778, "tag_name": "生日作", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "3545138": {"data": {"tag_id": 3545138, "tag_name": "Hello/HowAreYou", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1495346700, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "11265": {"data": {"tag_id": 11265, "tag_name": "手工", "cover": "http://i0.hdslb.com/bfs/archive/14387036f432cbc08a3c40662ea81ac49bdc0945.jpg", "head_cover": "http://i0.hdslb.com/bfs/archive/aed17e61786bc61f64e71abe32436540b9fb38f0.jpg", "content": "我有一双巧手，让生活更有情趣~", "short_content": "为什么你们的手如此优秀~", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "4198": {"data": {"tag_id": 4198, "tag_name": "海贼王", "cover": "http://i1.hdslb.com/sp/e9/e97c8756caf80c89188f2fc3030490c8_s.jpg", "head_cover": "", "content": "《海贼王》是尾田荣一郎在《周刊少年JUMP》上连载的超人气漫画。“ONE PIECE”在故事中为“一个大秘宝”之意。传说中‘海贼王’哥尔·D·罗杰在死前说出他留下了具有财富、名声、力量世界第一的宝藏“ONE PIECE”，许多人为了争夺“ONE PIECE”，争相出海，许多海贼开始树立霸权，而形成了“大海贼时代”。十年后，蒙其·D·路飞为了要实现与因救他而断臂的四皇‘红发’香克斯的约定而出海，在遥远的路途上找寻着志同道合的伙伴，一起进入“伟大航道”，目标：当上“海贼王”。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "2800": {"data": {"tag_id": 2800, "tag_name": "绘画", "cover": "http://i0.hdslb.com/bfs/archive/55efd27adbad18f19cb495fe1bfcbf197d003f5a.png", "head_cover": "", "content": "从原始的象形纹样到现代使用计算机绘画的一门艺术", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "13175": {"data": {"tag_id": 13175, "tag_name": "化妆", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1141438": {"data": {"tag_id": 1141438, "tag_name": "美妆教程", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "1697": {"data": {"tag_id": 1697, "tag_name": "教程", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 2, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atte
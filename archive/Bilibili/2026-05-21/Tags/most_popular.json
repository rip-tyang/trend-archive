"content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "536": {"data": {"tag_id": 536, "tag_name": "原创", "cover": "", "head_cover": "", "content": "1", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "156182": {"data": {"tag_id": 156182, "tag_name": "万万没想到", "cover": "http://i0.hdslb.com/bfs/tag/b6ad614adfc505f2f53007c367c1e3be63e73dda.jpg", "head_cover": "", "content": "《万万没想到》以夸张而幽默的方式描绘了屌丝代表王大锤意想不到的传奇故事。剧情内容包罗万象，从当下热门话题到经典历史故事，调侃的视角幽默的语言独树一帜。作为职场界，名医届，相亲届的著名屌丝，王大锤每天的生活都多姿多彩而又变幻莫测。本来只是一场很简单的面试，但在王大锤看来却变成了一个探案现场，最后的面试结果更是让人意想不到；本来很经典的刘备大义摔儿的故事，在王大锤眼里却变成了一场啼笑皆非的闹剧，从而深刻揭露了刘备的另外一面…\r\n　　王大锤代表着在大社会和各种压力下生活的普通群众，他面对的是每一个人都会经历的，而我们每一个人也确实都承受着世间的千奇百怪和万万想不到的意外。影片从王大锤开始，幻化出你我他的普通生活，教会我们对挫折一笑而过决不妥协。\r\n　　本作由叫兽易小星导演，优酷出品，剧组成员为《搞笑漫画日和》中文配音原班人马。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "27215934": {"data": {"tag_id": 27215934, "tag_name": "学生的迷惑行为", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1655350343, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "71436245": {"data": {"tag_id": 71436245, "tag_name": "Driss阿迪", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1738063033, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "8620
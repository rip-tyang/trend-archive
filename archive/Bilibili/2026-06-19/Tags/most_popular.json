ad_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "62330": {"data": {"tag_id": 62330, "tag_name": "英超", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "54377": {"data": {"tag_id": 54377, "tag_name": "挪威", "cover": "http://i0.hdslb.com/bfs/tag/16c81af0f1dc094b0c349e41611eaee3d0e75686.jpg", "head_cover": "", "content": "挪威（Norway），全称为挪威王国（The Kingdom of Norway, Kongeriket Norge）。 意为“通往北方之路”，位于斯堪的纳维亚半岛西部。挪威领土南北狭长，海岸线漫长曲折，沿海岛屿很多，被称为“万岛之国”。首都为奥斯陆。总面积38.5万平方公里。曾连续六年被联合国评为最适宜居住的国家，并于2009年到2013年连续获得全球人类发展指数第一的排名。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "584": {"data": {"tag_id": 584, "tag_name": "足球", "cover": "http://i0.hdslb.com/bfs/tag/150a100ebe674fd61d1aa3a8d1fff41705ad9efc.jpg", "head_cover": "", "content": "足球是足球运动或足球比赛的简称\r\n现代足球运动源于英国，亦为当今世界上开展最广、影响最大的体育项目之一，被认为是世界第一运动，在和平年代亦被称作是“国与国间没有硝烟的战争”，甚至因其丰富的内涵和感染力被视作一门艺术。", "short_content": "", "type": 2, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "67964": {"data": {"tag_id": 67964, "tag_name": "曼城", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "37112": {"data
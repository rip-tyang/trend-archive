, "dimension": {"width": 1920, "height": 1080, "rotate": 0}, "short_link_v2": "https://b23.tv/BV1Ftjw6DEmL", "first_frame": "http://i0.hdslb.com/bfs/storyff/_0000185769owxfv1b2aoerbuxwqxoib_firsti.jpg", "pub_location": "中国香港", "cover43": "http://i0.hdslb.com/bfs/archive/fabbd47c05b169b7f7c907b3f066b0b99306f056.jpg", "tidv2": 2043, "tnamev2": "动漫速读", "pid_v2": 1005, "pid_name_v2": "二次元", "bvid": "BV1Ftjw6DEmL", "season_type": 0, "is_ogv": false, "ogv_info": null, "enable_vt": 0, "ai_rcmd": null, "rcmd_reason": {"content": "百万播放", "corner_mark": 1}}, {"aid": 116758971156602, "videos": 1, "tid": 178, "tname": "科学·探索·自然", "copyright": 2, "pic": "http://i1.hdslb.com/bfs/archive/776c95992a9aff66eded6231bde25db6ae039809.jpg", "title": "【纪录片】地球·劫后重生 中配版02 气候巨变", "pubdate": 1781841602, "ctime": 1781604816, "desc": "2.32亿年前的盘古大陆，持续百万年的暴雨造就了生机盎然的世界，彼时恐龙尚未主导地球，伊斯基瓜拉斯托兽等古老爬行动物在此繁衍，它们依赖叉叶松生存，在兽群争斗、滥食龙、蜥鳄等天敌威胁中维系族群。随后驱动季风的火山活动平息，暴雨戛然而止，漫长干旱席卷大地，叉叶松锐减、湖泊干涸，伊斯基瓜拉斯托兽因食谱单一陷入生存危机，族群大幅缩减。而喙头龙类等生物与之争夺食物，生存竞争愈发残酷，气候也在洪泛雨林与干旱沙漠间剧烈波动，半数物种消亡。最终气候趋于稳定，适应能力极强的恐龙崛起，取代古老爬行动物成为地球霸主。", "state": 0, "duration": 2414, "redirect_url": "https://www.bilibili.com/bangumi/play/ep4350999", "rights": {"bp": 0, "elec": 0, "download": 0, "movie": 0, "pay": 1, "hd5": 0, "no_reprint": 0, "autoplay": 0, "ugc_pay": 0, "is_cooperation": 0, "ugc_pay_preview": 0, "no_background": 0, "arc_pay": 0, "pay_free_watch": 0}, "owner": {"mid": 7584632, "name": "哔哩哔哩纪录片", "face": "https://i2.hdslb.com/bfs/face/d655b5efeb97cb4ca5d4926bc53cddee66f429a5.jpg"}, "stat": {"aid": 116758971156602, "view": 639282, "danmaku": 117, "reply": 67, "favorite": 715, "coin": 233, "share": 62, "now_rank": 0, "his_rank": 0, "like": 1770, "dislike": 0, "vt": 0, "vv": 639282, "fav_g": 0, "like_g": 431}, "dynamic": "#地球·劫后重生#第二集中配版上线！2.32亿年前的盘古大陆是什么样？伊斯基瓜拉斯托兽依赖叉叶松生存，在兽群争斗、滥食龙、蜥鳄等天敌威胁中维系族群。然而气候巨变，生存竞争愈发残酷，半数物种消亡。最终气候趋于稳定，适应能力极强的恐龙崛起，取代古老爬行动物成为地球霸主。每周五中午12点，在浩劫中感受生命的力量。", "cid": 39160512609, "dimension": {"width": 3840, "height": 2160, "rotate": 0},
time": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 2}, "11666": {"data": {"tag_id": 11666, "tag_name": "战锤40K", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "3813": {"data": {"tag_id": 3813, "tag_name": "同人", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "9887": {"data": {"tag_id": 9887, "tag_name": "战锤", "cover": "http://i0.hdslb.com/bfs/tag/5753c1522310ed66dbc6513f3cf145341a44d334.jpg", "head_cover": "", "content": "　　战锤40000（Warhammer 40,000或是Warhammer 40K）是一款桌上战棋游戏，由英国游戏公司Games Workshop制作。\n　　所谓桌上战棋游戏，是指使用棋子和骰子在沙盘上进行的模拟战斗游戏，这种游戏类型早在上世纪中期就已经在欧美出现了，不过当时还仅限于用历史上的真实战役来进行游戏。\n　　一九七零年《魔戒》风靡世界，同时带动了一大批战略类游戏的出现与发展。（注：LotR的桌面游戏也是GW经营的一个项目）\n　　Games Workshop与70年代陆续推出了战锤和战锤40000两款桌面战棋游戏。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "13490": {"data": {"tag_id": 13490, "tag_name": "定格动画", "cover": "http://i0.hdslb.com/bfs/archive/d1ca379b712bc21b250abf7b88732b504e44ae8f.png", "head_cover": "http://i0.hdslb.com/bfs/archive/90ab76ecfb3619377f9683d983bdcbb1a2fa6afe.png", "content": "定格动画是通过逐格地拍摄对象然后使之连续放映，从而产生仿佛活了一般的人物或你能想象到的任何奇异角色。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "167": {"data": {"tag_id": 167, "tag_name": "猫和老鼠", "cover": "http://i0.hdslb.com/bfs/tag/655d7f13a1961a4e7f35c4bc91abf65e701e8b8b.jpg", "head_cover": "", "content": "《猫和老鼠》（Tom and Jerry）是由威廉·汉纳（William Hanna）和约瑟夫·巴伯拉（Joseph Barbera）自1940年起制作的动画系列。作品共分为163集短剧（1940-2005），5部TV版（1975-2014），10部电影版（1992-2013）。\r\n汉纳-巴伯拉/米高梅动画时期制作114集（1940-1957），期间获得了7次奥斯卡最佳动画短片奖；\r\nGene Deitch/Rembrandt Films cartoons时期制作13集（1961-1962）；\r\n查克·琼斯/Sib Tower 12 cartoons时期制作34集（1963-1967）；\r\n汉纳-巴伯拉/透纳娱乐时期制作1集The Mansion Cat（2001）；\r\n华纳动画时期制作1集The Karate Guard（2005）；\r\n以上为163集短剧作品。\r\n1992制作了首部电影版作品Tom and Jerry: The Movie。\r\n2014年推出新TV版动画。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "2676001": {"data": {"tag_id": 2676001, "tag_name": "手办模玩", "cover": "http://i0.hdslb.com/bfs/archive/95ecb88ac337d76d1c4fb9d836e8b794cf39e5b6.jpg", "head_cover": "http://i0.hdslb.com/bfs/archive/9b2c7d41259ef08b53e0fbe8486f0e21981cf3fc.png", "content": "缩小了的他们，代表着我们的浪漫", "short_content": "诱惑你剁手的地方", "type": 3, "state": 0, "ctime": 1475278517, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "3006": {"data": {"tag_id": 3006, "tag_name": "模型", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 2, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "3570099": {"data": {"tag_id": 3570099, "tag_name": "暗源", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1495881880, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "
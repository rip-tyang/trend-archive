   他辩解自己火暴脾气的理由是：如果不在厨房里开火，厨师怎么会有热情？而正是因为有格登.拉姆齐的参加，才赋予了“地狱”两字更直接的意义。和他一起录制《地狱厨房》的多名参赛选手，身份各异。有厨房帮工，保险公司职员，单身妈妈，居然还有大学学生。他们因为共同的爱好走到了一起。\r\n", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "3845": {"data": {"tag_id": 3845, "tag_name": "解说", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "8952": {"data": {"tag_id": 8952, "tag_name": "纪录片", "cover": "http://i0.hdslb.com/bfs/tag/4c12dfe97b89c01e66388ebbbf048c8f880ec0c6.jpg", "head_cover": "", "content": "纪录片是以真实生活为创作素材，以真人真事为表现对象，并对其进行艺术的加工与展现的，以展现真实为本质，并用真实引发人们思考的电影或电视艺术形式。纪录片的核心为真实。电影的诞生始于纪录片的创作。", "short_content": "", "type": 2, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "88226386": {"data": {"tag_id": 88226386, "tag_name": "戈登的心里咯噔一下", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1767954163, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "421428": {"data": {"tag_id": 421428, "tag_name": "沙雕", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "16109": {"data": {"tag_id": 16109, "tag_name": "戈登", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637
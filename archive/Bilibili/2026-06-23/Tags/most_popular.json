hdslb.com/bfs/archive/c1adabb8119f40f0d2d7efc200213dbf69c8d8b1.png", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "3713": {"data": {"tag_id": 3713, "tag_name": "访谈", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "36909": {"data": {"tag_id": 36909, "tag_name": "萧敬腾", "cover": "http://i0.hdslb.com/bfs/tag/822052c097b4bfe3ee9e1c3239647b87a0a9cfc0.jpg", "head_cover": "", "content": "萧敬腾，1987年3月30日出生于台北。少年叛逆，因为音乐浪子回头。07年星光大道因踢馆成名，未出道已红遍台湾；08年签约华纳唱片并推出首张同名个人专辑，横扫台湾；09年发行《王妃》专辑以及《love moments》爱的时刻精选辑；2011年《狂想曲》展现其强大的live实力；2012年推出《Mr.Jazz》全英文爵士乐专辑以及限量黑胶唱盘，并发行《以爱之名》个人专辑，也凭借此张专辑问鼎24届台湾金曲奖金曲歌王。年仅26岁，2场世界巡回演唱会，三攻小巨蛋，几登红磡。从邓丽君到MJ，从江蕙到Bon Jovi，从张雨生到Eagles，从张学友到Aerosmith；从摇滚到爵士，从洛克到抒情；从低音到高音，从主声到和声；从钢琴到爵士鼓，从keyboard到吉他；从桌球到乒乓，从保龄球到篮球；从慈善到公益，低调做人，高调做事。只有萧敬腾才能超越萧敬腾。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "20246400": {"data": {"tag_id": 20246400, "tag_name": "HOPICO", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1623964584, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "80836207": {"data": {"tag_id": 80836207, "tag_name": "小米YU7 GT", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1755850688, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0,
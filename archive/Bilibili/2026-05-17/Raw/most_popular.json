e/1a151c7c5d4ca5a46a3626367a754e250e6efd35.jpg", "title": "天大喜讯！四川全省禁止戒网瘾学校！", "pubdate": 1778979900, "ctime": 1778948000, "desc": "天大喜讯！四川全省禁止戒网瘾学校！\n \nHello大家好，我是温柔。\n \n熟悉我的朋友都知道，我是豫章书院事件的曝光者，这些年也一直在和戒网瘾学校或者特训机构这种极度残害未成年人的机构做斗争，也救了很多被抓进戒网瘾学校的成年人或者未成年人，制作揭露这类机构的视频或文章上亿次观看。\n \n今天我想说一个天大的好消息。\n \n四川省从5月30日开始，全省禁止一切戒网瘾学校，特训机构或者是军事夏令营，或者是其他一切类似的机构。\n \n这是四川省教育厅等十五部门共同印发的文件，《四川省加强未成年人不良行为教育管理办法》", "state": 0, "duration": 307, "rights": {"bp": 0, "elec": 0, "download": 0, "movie": 0, "pay": 0, "hd5": 0, "no_reprint": 0, "autoplay": 1, "ugc_pay": 0, "is_cooperation": 0, "ugc_pay_preview": 0, "no_background": 0, "arc_pay": 0, "pay_free_watch": 0}, "owner": {"mid": 265059948, "name": "温柔JUNZ", "face": "https://i0.hdslb.com/bfs/face/0c0c0b56f31f391a039fb4208314ee47526fab4b.jpg"}, "stat": {"aid": 116585125646122, "view": 575470, "danmaku": 1481, "reply": 5380, "favorite": 12185, "coin": 31395, "share": 3986, "now_rank": 0, "his_rank": 49, "like": 103167, "dislike": 0, "vt": 0, "vv": 575470, "fav_g": 0, "like_g": 992}, "dynamic": "这是胜利的重要一步！", "cid": 38385813489, "dimension": {"width": 1920, "height": 1080, "rotate": 0}, "short_link_v2": "https://b23.tv/BV1DfLV6PEoT", "first_frame": "http://i2.hdslb.com/bfs/storyff/_000005otqbmztss6q2t8gv0z46jqvwb_firsti.jpg", "pub_location": "浙江", "cover43": "http://i0.hdslb.com/bfs/archive/e26aecd6ff6a3d9e4905f496c9b8de67e9f9ac7b.jpg", "tidv2": 2088, "tnamev2": "社会观察", "pid_v2": 1010, "pid_name_v2": "知识", "bvid": "BV1DfLV6PEoT", "season_type": 0, "is_ogv": false, "ogv_info": null, "enable_vt": 0, "ai_rcmd": null, "rcmd_reason": {"content": "10万点赞", "corner_mark": 1}}, {"aid": 116577341019795, "videos": 1, "tid": 239, "tname": "家居房产", "copyright": 1, "pic": "http://i2.hdslb.com/bfs/archive/bb0b972ce70212a0d1bd420eb4248df5581d358b.jpg", "title": "这个视频会成为你26年最难忘的回忆", "pubdate": 1778837400, "ctime": 1778829506, "desc": "俗话说的好，来得晚必然来得大，给大家憋了期大的，are you ok？", "state": 0, "duration": 1050, "mission_id": 4064914, "rights": {"bp": 0, "elec": 0, "d
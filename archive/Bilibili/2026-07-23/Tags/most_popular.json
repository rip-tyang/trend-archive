 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "2947": {"data": {"tag_id": 2947, "tag_name": "特摄", "cover": "http://i0.hdslb.com/bfs/archive/11d6f73281947ac0d0371897241ad9ef5530b6b6.jpg", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "13784": {"data": {"tag_id": 13784, "tag_name": "迪迦奥特曼", "cover": "http://i0.hdslb.com/bfs/tag/5849230d7d6a7802512531fd91304625bfff001a.jpg", "head_cover": "", "content": "迪迦在印度尼西亚语中，代表了神圣的数字&amp;amp;amp;amp;quot;3&amp;amp;amp;amp;quot;。大约三千万年以前，地球处于超古代，奇杰拉花朵盛开，邪神加坦杰厄降临，巨人们发生内战，原是地球最强的黑暗战士迪迦在受幽怜的感动后化为光，使其黑暗力量长眠。但超古代文明并没有因此而得救，人们全部都迷上了奇杰拉花的花粉，因为光之巨人无法干涉人类的选择，所以巨人把自己战斗的躯体隐藏在金字塔后，化作光离开了地球", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "963": {"data": {"tag_id": 963, "tag_name": "奥特曼", "cover": "http://i0.hdslb.com/bfs/tag/0f84368a89745bdbe5dd75bf1e7a5a17cc4ac8e2.jpg", "head_cover": "", "content": "奥特曼（Ultraman 日：ウルトラマン）是日本圆谷株式会社拍摄的科学空想特摄电视连续剧，由杂志连载、电影、电视剧变成节目演变出现。奥特曼在普通人眼中是高大的巨人，就如同神一般的存在，可是他们对于自己的种族，自己的星球来说也只不过是一个普通人。超进化给他们带来了完善的生命形态，同时也使他们背负起了沉重的历史责任，在这种历史责任感驱使下，光之巨人的足迹遍步宇宙，而其中有这么几位巨人，他们来到了我们所在的地球，邂逅了宇宙中最奇妙也是最难以捉摸的生命体—人类。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "28745": {"data": {"tag_id": 28745, "tag_name": "迪迦", "cover": "http://i0.hdslb.com/bfs/tag/19501acb173723b9d19d366c4e373fbb7fee6b8e.jpg", "head_cover": "", "content": "迪迦奥特曼  ", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "68": {"data": {"tag_id": 68, "tag_name": "鬼畜", "cover": "http://i0.hdslb.com/bfs/archive/5f42290e9299eceb7dfce4b932b497d1255ea847.jpg", "head_cover": "http://i0.hdslb.com/bfs/archive/af941ccd50c12c1ccd91869bfcc6fb22d71b458f.png", "content": "起源于NICONICO动画，由最早出现的音MAD《最终鬼畜妹フランドール・S》中的“鬼畜”略称而得名。", "short_content": "以音频调教创作为主体的二次创作", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1411": {"data": {"tag_id": 1411, "tag_name": "童年", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "43204": {"data": {"tag_id": 43204, "tag_name": "诺亚", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "7375172": {"data": {"tag_id": 7375172, "tag_name": "整活", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1528119428, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "13160": {"data": {"tag_id": 13160, "tag_name": "学习", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "8816": {"data": {"tag_id": 8816,
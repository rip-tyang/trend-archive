content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "89943283": {"data": {"tag_id": 89943283, "tag_name": "青年鬼鲛", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1770971972, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "59163": {"data": {"tag_id": 59163, "tag_name": "格斗游戏", "cover": "http://i0.hdslb.com/bfs/tag/e9204772636065e48b5438390620f2efa290f6ff.jpg", "head_cover": "", "content": "格斗游戏（Fighting Game）是指玩家操纵自己选择的角色以武术打斗的方式与计算机或其他玩家控制的角色对战的电视游戏或电脑游戏，和射击游戏一样多见於街机（大型电玩），系统及设定和那些与真实的体育项目有关的体育类游戏有著明显的区别。格斗游戏又可分為两种有著相似之处但又明显不同的种类。", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "1288454": {"data": {"tag_id": 1288454, "tag_name": "火影忍者手游", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1437982235, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1429635": {"data": {"tag_id": 1429635, "tag_name": "火影手游", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1447241952, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "1574027": {"data": {"tag_id": 1574027, "tag_name": "干柿鬼鲛", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1455940141, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0
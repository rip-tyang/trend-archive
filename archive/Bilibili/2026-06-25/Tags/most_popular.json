nt": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "356262": {"data": {"tag_id": 356262, "tag_name": "萌娃", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "164696": {"data": {"tag_id": 164696, "tag_name": "亲子", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "2503953": {"data": {"tag_id": 2503953, "tag_name": "Vlog", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1471257832, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "43184298": {"data": {"tag_id": 43184298, "tag_name": "我们的家庭日记", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1691344453, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1394": {"data": {"tag_id": 1394, "tag_name": "动漫", "cover": "http://i0.hdslb.com/bfs/tag/d08c5fe17ceb793e7ce95d9c67392743b33b46d0.jpg", "head_cover": "", "content": "      “动漫”是动画和漫画的合称与缩写。在其他语言相当少用。随着现代传媒技术的发展，动画（animation或anime）和漫画（comics，manga；特别是故事性漫画）之间联系日趋紧密，两者常被合而为“动漫”。\n　   由于漫画本身的发展形成了现代故事漫画的表现形式，将影视艺术融入漫画之中，使得漫画与动画更容易结合，影视艺术独特的地方在于它能通过镜头的推拉摇移和片段剪辑的蒙太奇技巧来表达想法和感受。漫画正是吸收了影视艺术的这两个特点。当讲述的故事越发复杂、人物越发丰富的时候，传统单线式叙事的方法就越行不通，蒙太奇的介入就成为一种需要了；当漫画家在传统表现手段中无法找到更合适的抒发感情的方法的时候，当读者需要作品有更强的冲击力和表现力的时候，各种镜头的灵活运用就成为一种必需了。一部现代故事漫画往往集远、中、近、特四种镜头于一身，漫画家往往能熟练地运用镜头的移动和各种蒙太奇剪接，对故事特定部分的情绪和氛围进行渲染。这就是现代故事漫画容易和动画结合的一个原因，因为它天生就像动画的分镜头剧本，读者在看漫画时如同在看一部电影。正是有着这样的相似性所以如今将动画和漫画合称为“动漫”。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "81462648": {"data": {"tag_id": 81462648, "tag_name": "Vlog生活B面", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1756888913, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "51486": {"data": {"tag_id": 51486, "tag_name": "奇幻", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "16593117": {"data": {"tag_id": 16593117, "tag_name": "记忆管理局", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1600156362, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "5242": {"data": {"tag_id": 5242, "tag_name": "战斗", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "110511": {"data": {"tag_id": 110511, "tag_name": "开箱", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "128
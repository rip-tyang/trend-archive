 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "5912": {"data": {"tag_id": 5912, "tag_name": "手办", "cover": "http://i0.hdslb.com/bfs/tag/8589b7943c66bc111bc37081756c806e595d540e.jpg", "head_cover": "", "content": "（日语：ガレージキット、英语：GARAGE KIT）经常会被当作人形（フィギュア）。但其真正意义上的手办都是表现原型师个性的GARAGE KIT（简称GK），是指没有涂装的模型套件。很多人会误解其为所有树脂材质的人形作品，但其特指的就是未涂装的模件。因为在开模的复杂度上有着很高的难度，因此价格一般都很昂贵。因为树脂材料的特性，很适合表现非常细致的细节部分和人物。大部分手办都是工厂提供的半成品白模，需要自己动手打磨、拼装、上色等一系列复杂的工艺，而且难度远大于一般模型制作。单单从上色来说，需要一定的美术功底以及喷笔这样昂贵的涂装工具。 \n但在现在很多玩家都习惯了手办指人形的用法。 ", "short_content": "", "type": 2, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "42642704": {"data": {"tag_id": 42642704, "tag_name": "三角洲行动", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1690432697, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "96349433": {"data": {"tag_id": 96349433, "tag_name": "三角洲彩虹六号联动", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1781320500, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "51458": {"data": {"tag_id": 51458, "tag_name": "核电站", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "85044": {"data": {"tag_id": 85044, "tag_name": "小车", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime
 "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "5506": {"data": {"tag_id": 5506, "tag_name": "敖厂长", "cover": "http://i0.hdslb.com/bfs/tag/20551c18921341e1a4f2e760e0db125409d78c4f.jpg", "head_cover": "", "content": "敖厂长制作的《囧的呼唤》系列是国内目前点击率最高的单机游戏讲解类视频，也是以游戏娱乐讲解和游戏文化探讨为主旋律的在线系列视频。敖厂长最为成功的作品便是从09年7月开始制作的一系列原创剧情的《囧的呼唤》，受到了BAIDU贴吧、各大视频网站网友们的喜爱。 ", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "962": {"data": {"tag_id": 962, "tag_name": "怀旧", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "436": {"data": {"tag_id": 436, "tag_name": "命令与征服", "cover": "http://i0.hdslb.com/bfs/tag/20f8851996b32f9bbaacfb57cecf68981fece75d.jpg", "head_cover": "", "content": "命令与征服，英文名： Command &amp; Conquer，台译：终极动员令 简称C&amp;C或CNC，是美国Westwood Studios为个人电脑发行的一系列即时战略游戏（RTS-Real Time Strategy）。美国艺电（Electronic Arts）收购Westwood之后，将本系列扩张成数个系列的共同商标。\r\n命令与征服 一共出现过3个系列 包括泰伯利亚系列（包括变节者[也作《叛逆者》]，有些人以为变节者是独自一个系列，但是变节者用的是C&amp;C1的剧情）、红色警戒系列（红色警戒是本传的前传，红色警戒2是在一个新的时空中发生的，红色警戒3则与红色警戒2为平行时空，与泰伯利亚系列无关）、将军系列（与前两个系列完全无关）。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "74373": {"data": {"tag_id": 74373, "tag_name": "游戏杂谈", "cover": "http://i0.hdslb.com/bfs/tag/6057e57134c1f2e7960cb7daa18aa350e6721dc0.png", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "22999": {"data": {"tag_id": 22999, "tag_name": "即时战略", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "47377": {"data": {"tag_id": 47377, "tag_name": "正版", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1009": {"data": {"tag_id": 1009, "tag_name": "任天堂", "cover": "http://i0.hdslb.com/bfs/tag/566013ebcd84ad9bf7365475dbb3cdd9088b2567.png", "head_cover": "", "content": "任天堂（日文：にんてんどう，英文：Nintendo）公司成立于1889年，原为生产纸牌的手工作坊，现是日本最著名的游戏制作公司，其制作的电子游戏及主机、掌机系列在全球范围内深受欢迎。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "5219": {"data": {"tag_id": 5219, "tag_name": "塞尔达", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "17683": {"data": {"tag_id": 17683, "tag_name": "单机游戏", "cover": "http://i0.hdslb.com/bfs/archive/325212cab74a3c57632f3c9a3a3acb9671616a99.jpg", "head_cover": "http://i0.hdslb.com/bfs/archive/dce991bba19a4220883c172506e8f27220eddcc3.jpg", "content": "以所有平台（PC、主机、移动端）的单机或联机游戏为主的视频内容，包括游戏预告、CG、实况解说及相关的评测、杂谈等", "short_content": "我知道你曾是一个冒险家", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "13715": {"data": {"tag_id": 13715, "tag_name": "STEAM", "cover": "http://i0.hdslb.com/bfs/tag/8f9e58ea370f0ba529518d7a919d45183eeb7ed4.jpg", "head_cover": "", "content": "Steam平台是Valve公司聘请的BitTorrent协议(BT下载)发明者Bram·Cohen亲自开发设计的全球最大的综合性数字游戏软件发行平台。玩家可以在该平台购买游戏、软件、下载、讨论、上传、分享。\r\n\r\nSteam是一个整合游戏下载平台。2003年，Steam系统一起与CS1.6问世。至目前为止，Steam的运作十分成功广泛，无数游戏在此平台上发行、更新。\r\n\r\n至于为什么叫“Steam”。在Steam平台上下载游戏的速度是非常快的，速度就像蒸汽一样喷薄而出，快得令人难以置信，所以名曰Steam。一般情况下可达到满速（请选择美国服务器节点）。——来源于百度", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "18034355": {"data": {"tag_id": 18034355, "tag_name": "switch 2", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1609977109, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "188171": {"data": {"tag_id": 188171, "tag_name": "直面会", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "24133": {"data": {"tag_id": 24133, "tag_name": "林克", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "43949": {"data": {"tag_id": 43949, "tag_name": "角色扮演", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0
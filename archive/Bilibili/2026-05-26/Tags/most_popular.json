息传送过去的时间机器。在他们对未来及过去知道得越多的同时，却不知道危难正渐渐临到自己身上……\r\n\r\nSteins;Gate（命运石之门，日语：シュタインズ・ゲート）是2009年10月15日发售的一款Xbox 360游戏，Windows版本于2010年8月26日发售。继《CHAOS;HEAD》之后，5pb.与Nitro+合作企划的“科学系列”冒险游戏（ADV）的第二作，假想科学ADV。Fami通赏2009优秀赏受奖作品。已于2011年4月TV动画化。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "358": {"data": {"tag_id": 358, "tag_name": "动画", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "61558": {"data": {"tag_id": 61558, "tag_name": "小麦", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "42642704": {"data": {"tag_id": 42642704, "tag_name": "三角洲行动", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1690432697, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 2}, "64147375": {"data": {"tag_id": 64147375, "tag_name": "三角洲欢乐剧场", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1730885176, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 3}, "91925701": {"data": {"tag_id": 91925701, "tag_name": "updream", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1774664184, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "
 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "8816": {"data": {"tag_id": 8816, "tag_name": "英语", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "60381": {"data": {"tag_id": 60381, "tag_name": "医疗", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "5794": {"data": {"tag_id": 5794, "tag_name": "美国", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 4}, "60385": {"data": {"tag_id": 60385, "tag_name": "仁医", "cover": "http://i0.hdslb.com/bfs/tag/0ee7ef8f77cf95c7b734c4be7b8f41c5972ed712.jpg", "head_cover": "", "content": "这部知名漫画家村上本加的作品，主人公脑外科医生南方仁从现代穿越时空回到古代幕府，运用现代的医疗技术拯救了许多江户人民，并和幕府末期英雄坂本龙马、胜海舟等进行交流。对主演大泽来说，是自2001年以来的首次主演连续剧，中谷美纪也是时隔7年再次出演连续剧。\r\n这部《仁医》自2000年开始连载以来，现在已发行19卷单行本，连载业已完结。身为东都大学附属医院脑外科医局长，竟然穿越时空回到文久2年的江户。他一边改变着历史，一边用现代医疗技术拯救江户人民。主人公南方仁由大泽饰演。另外，中谷美纪一人分饰两角，一个是仁留在现代的未婚妻，一个是江户著名花魁。而绫濑遥则饰演仁的助手。\r\n历史上真实存在的历史人物坂本龙马由内野圣阳扮演，胜海舟一角交给小日向文世。而推动江户医学发展的绪方洪庵由武田铁矢扮演。另外小出惠介、户田菜穗等豪华演员也将一同出演。另外原作中还有西乡隆盛、冲田总司等新选组的成员登场，此次并未发表扮演人选。这些配角的人选也非常值得关注。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "32664428": {"data": {"tag_id": 32664428, "tag_name": "良医心", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1
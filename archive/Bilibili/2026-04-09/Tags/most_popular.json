ribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 2}, "331040": {"data": {"tag_id": 331040, "tag_name": "街头采访", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "11350583": {"data": {"tag_id": 11350583, "tag_name": "猜词挑战", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1564825930, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "41729014": {"data": {"tag_id": 41729014, "tag_name": "魏中咸", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 1, "state": 0, "ctime": 1688782366, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "305605": {"data": {"tag_id": 305605, "tag_name": "涨知识", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "52360": {"data": {"tag_id": 52360, "tag_name": "博士", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "10058": {"data": {"tag_id": 10058, "tag_name": "挑战", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "3141": {"data": {"tag_id": 3141, "tag_name": "电影", "cover": "http://i0.hdslb.com/bfs/tag/f19de3f4c7fd073da5edc0029fdbe8dd3b787498.jpg", "head_cover": "", "content": "电影，也称映画。是由活动照相术和幻灯放映术结合发展起来的一种现代艺术。是一门可以容纳文学戏剧、摄影、绘画、音乐、舞蹈、文字、雕塑、建筑等多种艺术的综合艺术，但它又具有独自的艺术特征。电影在艺术表现力上不但具有其它各种艺术的特征，又因可以运用蒙太奇这种艺术性极强的电影组接技巧，具有超越其它一切艺术的表现手段，而且影片可以大量复制放映。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "2544": {"data": {"tag_id": 2544, "tag_name": "美剧", "cover": "http://i0.hdslb.com/bfs/tag/d0b0472a4b988b0fb4bed1ed83b168bc375088d5.jpg", "head_cover": "", "content": "“美剧”是中国人对美国电视剧集的简称。上世纪80年代，一部拍摄于1970年的《大西洋底来的人》成为敞开国门之后中国人窥视美国的窗口，麦克·哈里斯 脸上的蛤蟆镜一度成为时尚青年的标志。《加里森敢死队》的热播、停播与复播更是中国人观念变化的晴雨表。《成长的烦恼》让我们走进美国家庭 ，体验了代际沟通的可能及其背后的美国式幽默。凡此种种，都已成为那个年代的文化切片。在长期的发展历程中，美剧的许多传统得以逐步确立，其中“季”的运营模式最为现代中国观众所了解。“季”是各大电视网播出新作品的季节，一般美国商业电视以每年从9月中旬开始到次年4月下旬，时长约30周。每年秋季，美国电视网纷纷推出自己的新剧，或者延续之前已经获得成功的经典剧集。新季以美国电视艺术与科学协会主办的“艾美奖”颁奖典礼为序幕。这段时间天气较冷，人们一般较少外出，电视的开机率和收视率自大幅提升。通过这种每年固定的播出时段，我们可以在许多长寿的美剧中找寻美国社会变迁的轨迹。由于2011年几大视频网站陆续在海外上市，许多优秀的美剧将出现在中国内地的电视屏幕上。一部美国电视剧一般25集左右，这是由美国特有的播映方式决定的。美国电视剧一般一个星期只播一集，因此25集正好够播一季。美国的电视剧是边拍边播的，他们很注重收视率，一部收视率低下的电视剧是无法生存的，只要吸引不了观众的注意力，那么不管该剧的情节进行到何处，电视台都毫不留情地腰斩。电视网是美国电视体系的主体，本质上是一家经营电视节目的大公司。通常，各大电视网在全国各地拥有许多电视台，他们向这些电视台提供节目内容。美国主要的电视网有以下几个：哥伦比亚广播公司（CBS）、全国广播公司（NBC）、美国广播公司（ABC）、福克斯广播公司（FOX）、哥伦比亚及华纳兄弟联合电视网（CW）、家庭电视广播网（HBO=Home Box Office）。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "5251": {"data": {"tag_id": 5251, "tag_name": "科幻", "cover": "http://i0.hdslb.com/bfs/archive/1e864e3ab3c0c73728c03fb6e900121096ab5cd9.jpg", "head_cover": "http://i0.hdslb.com/bfs/archive/01f91876cc434f70d39f650ddb28517f7b82fed5.jpg", "content": "未来是什么样的？", "short_content": "科学与幻想的未来间距", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "13881": {"data": {"tag_id": 13881, "tag_name": "超级英雄", "cover": "http://i0.hdslb.com/bfs/archive/d4dcd226ebac89b466b5e58d453d5af4287d5d2b.jpg", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "3845": {"data": {"tag_id": 3845, "tag_name": "解说", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "285700": {"data": {"tag_id": 285700, "tag_name": "满分", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1559077": {"data": {"tag_id": 1559077, "tag_name": "黑袍", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1455195901, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "8486440": {"data": {"tag_id": 8486440, "tag_name": "黑袍纠察队", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1538801972, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "91904633": {"data": {"tag_id": 91904633, "tag_name": "动画电影十级学者", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1774614424, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "9013": {"data": {"tag_id": 9013, "tag_name": "神话", "cover": "http://i0.hdslb.com/bfs/tag/9c0601ec0e4cac193b0ce58f8e986fe6f0bde42e.jpg", "head_cover": "", "content": "2010年，时尚青年易小川（胡歌饰演）来到父亲易教授的考古发掘现场，却意外卷入一起抢夺文物的事件。机缘巧合之下，他误打开了一个神秘的古代宝盒，与考古队的厨师高要一起穿越时空，回到了2200多年前的秦朝。在一次次的奇遇和历险之中，易小川经历了刻骨铭心的爱情，结交了忠肝义胆的朋友，蜕变成了仁心济世的蒙毅；而原本胆小怕事的高要，在经受了一连串致命打击后心性逆转，充满仇恨的心灵在权利的诱惑下变得贪婪冷酷，不择手段。2010年，哥哥易大川（任泉饰演）与父母一直没有放弃找到弟弟易小川的希望，他们一边对抗神秘势力的阻扰破坏，一边破解着一个个与易小川失踪有关的谜团。历险途中，易小川的父母解开了困扰他们多年的心结，易大川战胜了内心的胆怯，找到了自己的真爱。最后，他们打开了传说中的宝藏，找到了易小川的下落，全家人终得团聚，创下了令人感动的神话。可是小川心爱的玉漱公主却因长生药失效离他而去，小川对着电影版神话海报上的玉漱公主（金喜善饰）说：“你没有她漂亮！”对于易小川来说，这不仅仅是一个神话，还是一段真实。最后，小川孤独地走在街上，倾诉着对玉漱深沉的思念。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "58283": {"data": {"tag_id": 58283, "tag_name": "古装", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "8227": {"data": {"tag_id": 8227, "tag_name": "古风", "cover": "http://i0.hdslb.com/bfs/tag/535d44fb751b0613858303027d43ac2a63ba7d24.jpg", "head_cover": "", "content": "“古风”是一类新型的文化。“古风”以中国的传统文化为基调，结合中国传统的文学、琴棋书画、诗词歌赋等，经过不断的发展磨合，形成了比较完备的音乐、文学、绘画等艺术形式。古风文化正逐渐流行，受到越来越多的人喜爱。", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1296": {"data": {"t
 116730718391604, "videos": 1, "tid": 21, "tname": "日常", "copyright": 3, "pic": "http://i2.hdslb.com/bfs/archive/4a9c83dc2fe0b8e2f2b219b00fcb3d86f5886915.jpg", "title": "在上海吃到了玫瑰腐乳肉，长江这一路的酸甜苦辣咸脆鲜香咱也尝遍了！", "pubdate": 1781172032, "ctime": 1781169605, "desc": "这就是我们《长江吃饭故事》系列的全部内容了，一共10集。我们去年春天启程，从海拔5000多米的长江源出发，沿着长江跨越万里，最终奔向大海，很高兴能和大家一同走完这段旅程！\n“一条大河波浪宽”，为什么是一条大河？词作者乔羽先生早已给出答案，每个人的记忆里，可能都流淌着这样一条河。它或许是奔涌的大江，或许是蜿蜒的小河，又或许只是村口的一条无名小溪。只要你想起家，常常会想起这条河。\n这一路，我们讲了很多家与河的故事，在长江沿途，每一个地方每一个家都有自己不同的模样，也有自己不同的烦恼。但是他们最后都跟着长江一起", "state": 0, "duration": 3090, "mission_id": 4064351, "rights": {"bp": 0, "elec": 0, "download": 0, "movie": 0, "pay": 0, "hd5": 0, "no_reprint": 0, "autoplay": 1, "ugc_pay": 0, "is_cooperation": 0, "ugc_pay_preview": 0, "no_background": 0, "arc_pay": 0, "pay_free_watch": 0}, "owner": {"mid": 39627524, "name": "食贫道", "face": "https://i2.hdslb.com/bfs/face/eef12b850c10b0d7a7929236abb08604955823c0.jpg"}, "stat": {"aid": 116730718391604, "view": 633931, "danmaku": 4987, "reply": 1384, "favorite": 10553, "coin": 22551, "share": 2420, "now_rank": 0, "his_rank": 97, "like": 42804, "dislike": 0, "vt": 0, "vv": 633931, "fav_g": 0, "like_g": 41}, "dynamic": "长江吃饭故事完结啦~ 最后一站来到了上海", "cid": 39035408313, "dimension": {"width": 3840, "height": 2160, "rotate": 0}, "season_id": 5219365, "short_link_v2": "https://b23.tv/BV1GfEe6iE3x", "first_frame": "http://i0.hdslb.com/bfs/storyff/_00001uek9v0tnpytg27wzoeiqp1quhb_firsti.jpg", "pub_location": "北京", "cover43": "http://i1.hdslb.com/bfs/archive/4441179721ffbde0e0c769872ff35b2b8cf7bf50.jpg", "tidv2": 2150, "tnamev2": "美食探店", "pid_v2": 1020, "pid_name_v2": "美食", "bvid": "BV1GfEe6iE3x", "season_type": 0, "is_ogv": false, "ogv_info": null, "enable_vt": 0, "ai_rcmd": null, "rcmd_reason": {"content": "", "corner_mark": 0}}, {"aid": 116729929795808, "videos": 1, "tid": 65, "tname": "网络游戏", "copyright": 1, "pic": "http://i0.hdslb.com/bfs/archive/6d57fc21836a1ce8f052cdb1f6be0fef5a760cf6.jpg", "title": "一枪秒杀？三角洲S10新赛季爆料！打头算马枪？", "pubdate"
": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "27866": {"data": {"tag_id": 27866, "tag_name": "C罗", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "164936": {"data": {"tag_id": 164936, "tag_name": "葡萄牙", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "2687": {"data": {"tag_id": 2687, "tag_name": "NBA", "cover": "http://i0.hdslb.com/bfs/tag/de205ab9bdb20e618af99e0bbfc322c9cfc53f96.jpg", "head_cover": "", "content": "NBA（全称National Basketball Association），美国第一大职业篮球赛事，其中产生了威尔特·张伯伦、奥斯卡·罗伯逊、迈克尔·乔丹、科比·布莱恩特、勒布朗·詹姆斯等篮球巨星。该协会一共拥有30支球队，分属两个联盟：东部联盟和西部联盟；而每个联盟各由三个赛区组成，每个赛区有五支球队。30支球队当中有29支位于美国本土，另外一支来自加拿大的多伦多。从2009-10季后赛开始，因中国广电总局的相关规定，在中国电视转播中，解说员不再说“NBA”，而是极为别扭的用NBA的全称：美国职业篮球联赛，简称“美职篮”。\r\n", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "54564": {"data": {"tag_id": 54564, "tag_name": "西班牙", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 1}, "day_count": 1}, "41103": {"data": {"tag_id": 41103, "tag_name": "体育", "cover": "http://i0.hdslb.com/bfs/archive/0040e7e751933fd3f67189f6f0268ec096d3395c.png", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "23612": {"data": {"tag_id": 23612, "tag_name": "詹姆斯", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "1265": {"data": {"tag_id": 1265, "tag_name": "篮球", "cover": "http://i0.hdslb.com/bfs/tag/3c913f40349db7522bb35965c2d33cf696ce93f2.jpg", "head_cover": "", "content": "篮球是一个由两队参与的球类运动bcw，cc每队出场5名队员目的是将球进入对方球篮框中得分，并阻止对方获得球权和得分。可将球向任何方向传、投、拍、滚或运，但要受规则的限制。篮球比赛的形式多种多样，也有最流行的街头三人篮球赛，是三对三的比赛，更讲究个人技术。当今世界篮球水平最高的联赛是美国的国家篮球协会（NBA）。篮球在1904年列入奥运会的表演项目，到1936年柏林奥运会成为正式项目。女子篮球到1976年蒙特利尔奥运会才成为正式项目。", "short_content": "", "type": 2, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "95804325": {"data": {"tag_id": 95804325, "tag_name": "上B站！与世界干杯", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 0, "state": 0, "ctime": 1780566234, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "860": {"data": {"tag_id": 860, "tag_name": "日本", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0, "hates": 0, "attribute": 0, "liked": 0, "hated": 0, "extra_attr": 0}, "day_count": 1}, "221": {"data": {"tag_id": 221, "tag_name": "历史", "cover": "", "head_cover": "", "content": "", "short_content": "", "type": 3, "state": 0, "ctime": 1436866637, "count": {"view": 0, "use": 0, "atten": 0}, "is_atten": 0, "likes": 0,
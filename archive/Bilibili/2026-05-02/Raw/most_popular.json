/archive/a62b2b788a03b1c1f3af6bba502654cd8088ce94.jpg", "title": "「无敌少侠」以爱推至500年", "pubdate": 1777611600, "ctime": 1777562276, "desc": "由动画入坑，借鉴了一些动画的优点\n\n我喜欢无敌少侠这个作品，不是因为它的血腥暴力，而是其内在的亲情与责任，太阳之战给我的震撼绝对不亚于海虎三大结局，对比首男在沉默中爆发的劲霸强，马克更多的是无声的控诉，他以牺牲去守护的一切他所重视的，亲人朋友同胞，从他的成人礼到五百年后，所经历的一切从未彻底改变他，始终如一", "state": 0, "duration": 243, "mission_id": 4062557, "rights": {"bp": 0, "elec": 0, "download": 0, "movie": 0, "pay": 0, "hd5": 0, "no_reprint": 1, "autoplay": 1, "ugc_pay": 0, "is_cooperation": 0, "ugc_pay_preview": 0, "no_background": 0, "arc_pay": 0, "pay_free_watch": 0}, "owner": {"mid": 1182874343, "name": "望穿秋水145", "face": "https://i2.hdslb.com/bfs/face/1cccd57c9b98e7c22bb78d8aaec7bfb87dfd544d.jpg"}, "stat": {"aid": 116494310575000, "view": 1279463, "danmaku": 4097, "reply": 5883, "favorite": 81395, "coin": 99564, "share": 13297, "now_rank": 0, "his_rank": 8, "like": 166103, "dislike": 0, "vt": 0, "vv": 1279463, "fav_g": 2, "like_g": 0}, "dynamic": "", "cid": 37982834152, "dimension": {"width": 1920, "height": 1080, "rotate": 0}, "season_id": 8018215, "short_link_v2": "https://b23.tv/BV14C9YB6EKT", "first_frame": "http://i0.hdslb.com/bfs/storyff/_00002tdxiz83pk7v92unedge169jt4b_firsti.jpg", "pub_location": "河北", "cover43": "http://i0.hdslb.com/bfs/archive/07d641e9cd6485516d2421e5fca6462d9c944a46.jpg", "tidv2": 2041, "tnamev2": "动漫剪辑", "pid_v2": 1005, "pid_name_v2": "二次元", "bvid": "BV14C9YB6EKT", "season_type": 0, "is_ogv": false, "ogv_info": null, "enable_vt": 0, "ai_rcmd": null, "rcmd_reason": {"content": "百万播放", "corner_mark": 1}}, {"aid": 116500199445992, "videos": 1, "tid": 252, "tname": "仿妆cos", "copyright": 3, "pic": "http://i0.hdslb.com/bfs/archive/12db9fe505db4961a6d478d9ead1c9c5d9d1c00e.jpg", "title": "狼尊戴翅膀在星铁land横着走", "pubdate": 1777652376, "ctime": 1777652377, "desc": "-", "state": 0, "duration": 30, "rights": {"bp": 0, "elec": 0, "download": 0, "movie": 0, "pay": 0, "hd5": 0, "no_reprint": 0, "autoplay": 1, "ugc_pay": 0, "is_cooperation": 0, "ugc_pay_preview